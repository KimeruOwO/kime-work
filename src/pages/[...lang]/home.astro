    );
    --tile-h: calc(
      2 * var(--pad) + var(--h-top) + var(--gap) + var(--h-bottom)
    );

    position: absolute;
    top: 50%;
    left: -10vw;
    width: 200vw;
    height: var(--tile-h);
    transform-origin: 50vw center;

    background-color: var(--color-secondary-light);
