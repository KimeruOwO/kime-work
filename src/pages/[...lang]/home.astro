  .social-copy:hover {
    background-color: var(--base-white);
    color: var(--color-primary);
  }
  .social-copy:active {
    background-color: var(--base-white);
    color: var(--color-primary);
    transform: scale(0.95);
  }

  .contact-straight-strip-wrapper {
    position: relative;
    width: 100%;
    --b-gap: clamp(4px, 1vw, 8px);
    --b-h-top: clamp(6px, 1.5vw, 12px);
    --b-h-bottom: clamp(14px, 3.5vw, 28px);
    --b-pad: clamp(14px, 1vw, 18px);

    --tile-gap: var(--b-gap);
    --tile-h-top: var(--b-h-top);
    --tile-h-bottom: var(--b-h-bottom);
    --tile-pad: var(--b-pad);
    --sq-w: calc(var(--tile-h-top) + var(--tile-h-bottom) + var(--tile-gap));
    --logo-w: calc(var(--tile-h-bottom) * 4.8879);
    --margin-gap: clamp(8px, 4vw, 64px);
    --tile-w: calc(
      2 * var(--tile-pad) + var(--sq-w) + var(--tile-gap) + var(--logo-w) +
        var(--margin-gap)
    );
    --tile-h: calc(
      2 * var(--tile-pad) + var(--tile-h-top) + var(--tile-gap) +
        var(--tile-h-bottom)
    );

    height: var(--tile-h);
    background-color: var(--color-secondary-light);
    border-top: var(--border-width-md, 2px) solid var(--base-white);
    border-bottom: var(--border-width-md, 2px) solid var(--base-white);
    box-shadow: 0 4px 4px rgba(0, 0, 0, 0.12);

    background-image: url("/patterns/kimeyu-tile-cyan.svg");
    background-size: var(--tile-w) var(--tile-h);
    background-repeat: repeat-x;
    background-position: 0 center;
    animation: stripMoveRight 10s linear infinite;
  }

  @keyframes stripMoveRight {
    0% {
      background-position: 0 center;
    }
    flex-shrink: 0;
    font-size: clamp(11px, 1.2vw, 14px);
    font-weight: 900;
    color: var(--color-secondary-bright);
    background-color: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-sm);
    padding: 2px 8px;
    line-height: 1.4;
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
    margin-top: 3px;
  }

