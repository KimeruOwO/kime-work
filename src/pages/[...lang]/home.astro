    font-size: clamp(17px, 2vw, 24px);
    color: var(--base-white);
    margin-bottom: clamp(4px, 1vw, 8px);
    padding-bottom: clamp(8px, 1.5vw, 14px);
    border-bottom: 2px solid rgba(255, 255, 255, 0.15);
  }

