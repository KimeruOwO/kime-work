<script>
  const initCopyEngine = () => {
    const copyBtns = document.querySelectorAll<HTMLButtonElement>(".btn-copy");

    if (!copyBtns.length) return;

    copyBtns.forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        e.preventDefault();

        const text = btn.dataset.copyText;

        if (!text) {
          console.error("Clipboard Error: Missing data-copy-text");
          return;
        }

        try {
          if (!navigator.clipboard) {
            throw new Error(
              "Clipboard API bị chặn. Phải chạy trên HTTPS hoặc Localhost.",
            );
          }

          await navigator.clipboard.writeText(text);

          const originalHtml = btn.innerHTML;
          btn.innerHTML = `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>`;

          setTimeout(() => {
            btn.innerHTML = originalHtml;
          }, 1500);
        } catch (err) {
          console.error("Failed to write to Memory/Clipboard:", err);
        }
      });
    });
  };

  initCopyEngine();

  document.addEventListener("astro:page-load", initCopyEngine);

  // --- QUOTE REVEAL ON SCROLL ---
  const initQuoteReveal = () => {
    const section = document.querySelector<HTMLElement>(".contact-quote-block");
    if (!section) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            section.classList.add("is-revealed");
            observer.disconnect();
          }
        }
      },
      { threshold: 0.4 },
    );

    observer.observe(section);
  };

  initQuoteReveal();
  document.addEventListener("astro:page-load", initQuoteReveal);

  // Featured section: nim.design style — intercept wheel, translateY the fs-inner container
  const initFeaturedSnap = () => {
    const section = document.getElementById('featured-works-section');
    const inner = document.getElementById('fs-inner');
    if (!section || !inner) return;

    // Mobile bypass: Use standard intersection observer and skip scroll-jacking
    if (window.innerWidth <= 1024) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-active');
          }
        });
      }, { threshold: 0.2 });
      Array.from(inner.children).forEach(child => observer.observe(child));
      return;
    }

    const SLIDE_COUNT = inner.children.length; // 3 cards + 1 other-works
    const ANIM_DURATION = 700;
    const DELTA_THRESHOLD = 60;
    let currentSlide = 0;
    let isAnimating = false;
    let wheelDelta = 0;
    let activeSince = 0;

    const goTo = (index: number) => {
      currentSlide = Math.max(0, Math.min(SLIDE_COUNT - 1, index));
      inner.style.transform = `translateY(${-currentSlide * 100}%)`;
      
      Array.from(inner.children).forEach((child, i) => {
        if (i === currentSlide) {
          // Wait 400ms for the container to mostly slide into place before animating the contents
          setTimeout(() => {
            child.classList.add('is-active');
          }, 400);

        } else {
          // Delay removal so it doesn't snap out instantly while sliding away
          setTimeout(() => {
            child.classList.remove('is-active');
          }, ANIM_DURATION);
        }
      });

      isAnimating = true;
      setTimeout(() => { isAnimating = false; }, ANIM_DURATION);
    };

    // Use IntersectionObserver to trigger the first slide's animation only when it scrolls into view
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && currentSlide === 0) {
          if (inner.children[0]) {
            inner.children[0].classList.add('is-active');
          }
        }
      });
    }, { threshold: 0.3 });
    observer.observe(section);

    const isFeaturedActive = () => {
      const r = section.getBoundingClientRect();
      // section's sticky viewport is pinned to top
      const active = r.top <= 1 && r.bottom >= window.innerHeight - 1;
      if (active && activeSince === 0) {
        activeSince = Date.now();
      } else if (!active) {
        activeSince = 0;
      }
      return active;
    };

    const onWheel = (e: any) => {
      if (!isFeaturedActive()) return;

      // Give an 800ms cooldown after the section becomes active to absorb scroll momentum from scrolling down the page
      if (Date.now() - activeSince < 800) {
        e.preventDefault();
        return;
      }

      // If we are currently animating a slide change, block all wheel events!
      if (isAnimating) {
        e.preventDefault();
        return;
      }

      const r = section.getBoundingClientRect();

      // Allow exit: on last slide going down, skip the dead space instantly
      if (currentSlide === SLIDE_COUNT - 1 && e.deltaY > 0) {
        if (r.bottom > window.innerHeight + 5) {
          window.scrollTo({
            top: window.scrollY + r.bottom - window.innerHeight,
            behavior: 'auto'
          });
        }
        return;
      }
      
      // Allow exit: on first slide going up, skip the dead space instantly
      if (currentSlide === 0 && e.deltaY < 0) {
        if (r.top < -5) {
          window.scrollTo({
            top: window.scrollY + r.top,
            behavior: 'auto'
          });
        }
        return;
      }

      e.preventDefault();
      wheelDelta += e.deltaY;
      if (Math.abs(wheelDelta) < DELTA_THRESHOLD) return;
      const dir = wheelDelta > 0 ? 1 : -1;
      wheelDelta = 0;
      goTo(currentSlide + dir);
    };

    // Touch
    let touchY = 0;
    const onTouchStart = (e: any) => { touchY = e.touches[0].clientY; };
    const onTouchEnd = (e: any) => {
      if (!isFeaturedActive()) return;

      if (Date.now() - activeSince < 800) {
        return;
      }

      const dy = touchY - e.changedTouches[0].clientY;
      if (Math.abs(dy) < 30 || isAnimating) return;
      const dir = dy > 0 ? 1 : -1;
      if (currentSlide === SLIDE_COUNT - 1 && dir > 0) {
        const r = section.getBoundingClientRect();
        if (r.bottom > window.innerHeight + 5) {
          window.scrollTo({
            top: window.scrollY + r.bottom - window.innerHeight,
            behavior: 'auto'
          });
        }
        return;
      }
      if (currentSlide === 0 && dir < 0) {
        const r = section.getBoundingClientRect();
        if (r.top < -5) {
          window.scrollTo({
            top: window.scrollY + r.top,
            behavior: 'auto'
          });
        }
        return;
      }
      goTo(currentSlide + dir);
    };

    // Reset when scrolled back above the section
    const onScroll = () => {
      if (section.getBoundingClientRect().top > 10 && currentSlide !== 0) {
        currentSlide = 0;
        inner.style.transform = 'translateY(0)';
        Array.from(inner.children).forEach((child, i) => {
          if (i === 0) child.classList.add('is-active');
          else child.classList.remove('is-active');
        });
      }
    };

    window.addEventListener('wheel', onWheel, { passive: false });
    window.addEventListener('touchstart', onTouchStart, { passive: true });
    window.addEventListener('touchend', onTouchEnd, { passive: true });
    window.addEventListener('scroll', onScroll, { passive: true });
  };

  initFeaturedSnap();
  document.addEventListener('astro:page-load', initFeaturedSnap);
</script>
<style>

  /* ==============================================
     MOBILE OPTIMIZATIONS (CYBER-POP TECH V2)
     ============================================== */

  /* Hide desktop section entirely on mobile */
  @media (max-width: 1024px) {
    .featured-works-section {
      display: none !important;
    }
  }

  /* Mobile HUD Section V2 */
  .fs-pop-mobile {
    display: none;
  }

  @media (max-width: 1024px) {
    .fs-pop-mobile {
      display: flex;
      flex-direction: column;
      width: 100%;
      padding: var(--spacing-8) var(--spacing-4);
      background: var(--bg-primary);
      position: relative;
    }

    .fs-pop-list {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-5);
    }

    .fs-pop-card {
      display: flex;
      align-items: center;
      background: var(--bg-secondary);
      /* Cyber/Tech clip-path (chamfered corners) */
      clip-path: polygon(16px 0, 100% 0, 100% calc(100% - 16px), calc(100% - 16px) 100%, 0 100%, 0 16px);
      position: relative;
      text-decoration: none;
      transition: transform 0.2s cubic-bezier(0.25, 1, 0.5, 1);
      min-height: 110px;
    }

    .fs-pop-card:active {
      transform: scale(0.97) translateX(4px);
    }

    /* Left bright colored ribbon */
    .fs-pop-card::before {
      content: "";
      position: absolute;
      top: 0; left: 0; bottom: 0;
      width: 10px;
      background: var(--color-secondary);
      z-index: 1;
    }
    .fs-pop-card-alt::before {
      background: var(--color-primary);
    }

    /* Checker overlay for a bit of texture */
    .fs-pop-card::after {
      content: "";
      position: absolute;
      top: 0; right: 0; width: 40%; height: 100%;
      background-image: var(--checker-mask-uri);
      background-size: var(--checker-cell) var(--checker-cell);
      background-color: var(--color-secondary);
      opacity: 0.03;
      z-index: 0;
      /* Slanted end */
      clip-path: polygon(30px 0, 100% 0, 100% 100%, 0 100%);
    }
    .fs-pop-card-alt::after {
      background-color: var(--color-primary);
