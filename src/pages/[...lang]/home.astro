  .contact-instructions {
    list-style: none;
    padding: 0;
    position: relative;
    color: var(--base-white);
    font-size: clamp(16px, 1.8vw, 22px);
    line-height: 1.6;
    margin-bottom: clamp(40px, 6vw, 80px);
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: clamp(8px, 1.5vw, 14px);
  }

  .contact-instructions li:not(.instruction-strong) {
    display: flex;
    align-items: center;
    gap: clamp(16px, 2vw, 24px);
    background: rgba(255, 255, 255, 0.06);
    padding: clamp(12px, 1.5vw, 16px) clamp(16px, 2vw, 24px);
    clip-path: polygon(16px 0, 100% 0, 100% calc(100% - 16px), calc(100% - 16px) 100%, 0 100%, 0 16px);
    position: relative;
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), background 0.3s ease;
  }

  .contact-instructions li:not(.instruction-strong):hover {
    background: rgba(255, 255, 255, 0.12);
    transform: translateX(8px);
  }

  .contact-instructions li:not(.instruction-strong)::before {
    content: "";
