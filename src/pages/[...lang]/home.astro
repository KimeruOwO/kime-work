  /* ==============================================
     MOBILE OPTIMIZATIONS (CYBER-POP TECH V2)
     ============================================== */

  /* Hide desktop section entirely on mobile */
  @media (max-width: 1024px) {
    .featured-works-section {
      display: none !important;
    }
  }

  /* Mobile HUD Section V2 */
  .fs-pop-mobile {
    display: none;
  }

  @media (max-width: 1024px) {
    .fs-pop-mobile {
      display: flex;
      flex-direction: column;
      width: 100%;
      padding: var(--spacing-8) var(--spacing-4);
      background: var(--bg-primary);
      position: relative;
    }

    .fs-pop-list {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-5);
    }

    .fs-pop-card {
      display: flex;
      align-items: center;
      background: var(--bg-secondary);
      /* Cyber/Tech clip-path (chamfered corners) */
      clip-path: polygon(16px 0, 100% 0, 100% calc(100% - 16px), calc(100% - 16px) 100%, 0 100%, 0 16px);
      position: relative;
      text-decoration: none;
      transition: transform 0.2s cubic-bezier(0.25, 1, 0.5, 1);
      min-height: 110px;
    }

    .fs-pop-card:active {
      transform: scale(0.97) translateX(4px);
    }

    /* Left bright colored ribbon */
    .fs-pop-card::before {
      content: "";
      position: absolute;
      top: 0; left: 0; bottom: 0;
      width: 10px;
      background: var(--color-secondary);
      z-index: 1;
    }
    .fs-pop-card-alt::before {
      background: var(--color-primary);
    }

    /* Checker overlay for a bit of texture */
    .fs-pop-card::after {
      content: "";
      position: absolute;
      top: 0; right: 0; width: 40%; height: 100%;
      background-image: var(--checker-mask-uri);
      background-size: var(--checker-cell) var(--checker-cell);
      background-color: var(--color-secondary);
      opacity: 0.03;
      z-index: 0;
      /* Slanted end */
      clip-path: polygon(30px 0, 100% 0, 100% 100%, 0 100%);
    }
    .fs-pop-card-alt::after {
      background-color: var(--color-primary);
      opacity: 0.05;
    }

    /* Huge Background Watermark Number */
    .fs-pop-watermark {
      position: absolute;
      right: 10%;
      top: 50%;
      transform: translateY(-50%);
      font-family: 'Impact', var(--font-sans);
      font-size: 100px;
      color: rgba(4, 98, 119, 0.04);
      z-index: 0;
      pointer-events: none;
      letter-spacing: -0.05em;
    }
    .fs-pop-card-alt .fs-pop-watermark {
      color: rgba(250, 114, 157, 0.06);
    }

    .fs-pop-thumb-box {
      width: 120px;
      aspect-ratio: 16 / 9;
      flex-shrink: 0;
      margin: var(--spacing-4) var(--spacing-4) var(--spacing-4) var(--spacing-5);
      position: relative;
      z-index: 2;
    }

    /* Slanted Background shadow/layer behind thumbnail */
    .fs-pop-thumb-bg {
      position: absolute;
      top: 4px; left: 4px; right: -4px; bottom: -4px;
      background: var(--color-secondary);
      clip-path: polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px);
      z-index: 1;
      opacity: 0.5;
    }
    .fs-pop-card-alt .fs-pop-thumb-bg {
      background: var(--color-primary);
    }

    .fs-pop-thumb {
      width: 100%;
      height: 100%;
      object-fit: cover;
      position: relative;
      z-index: 2;
      clip-path: polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px);
    }

    /* Extra cut out graphic overlay on thumb */
    .fs-pop-thumb-cut {
      position: absolute;
      bottom: 0; right: 0;
      width: 20px; height: 20px;
      background: var(--bg-secondary);
      clip-path: polygon(100% 0, 100% 100%, 0 100%);
      z-index: 3;
    }

    .fs-pop-info {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-width: 0;
      z-index: 2;
    }

    .fs-pop-meta {
      display: flex;
      align-items: center;
      margin-bottom: 4px;
    }

    /* Slanted Label / Ribbon */
    .fs-pop-tag {
      color: #FFF;
      background: var(--color-secondary);
      padding: 2px 10px 2px 8px;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      font-weight: 800;
