---
import { languages, defaultLang, showDefaultLang } from '../../../i18n/ui';
import { useTranslations } from '../../../i18n/utils';
import Layout from "../../../layouts/Layout.astro";
import SectionHeader from "../../../components/SectionHeader.astro";
import ModeSwitch from "../../../components/ModeSwitch.astro";
import MotionGallery from "../../../features/motions/components/MotionGallery.astro";
import ArtworkGallery from "../../../features/artwork/components/ArtworkGallery.astro";
import { fetchVideos, fetchArtworks } from "../../../lib/hygraph";

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang: lang === defaultLang && !showDefaultLang ? undefined : lang }
  }));
}

const { lang } = Astro.params;
const currentLang = lang || defaultLang;
const t = useTranslations(currentLang as keyof typeof languages);

const [videos, artworks] = await Promise.all([
  fetchVideos(),
  fetchArtworks(),
]);

const makePage = <T,>(data: T[]) => ({
  data,
  currentPage: 1,
  lastPage: 1,
  size: data.length,
  total: data.length,
  start: 0, end: allArtworks.length - 1, url: { current: "/work/", prev: undefined, next: undefined },
});

const videoPage = makePage(videos);
const artworkPage = makePage(artworks);
---

<Layout title={`Kimeyu Work - ${t('works.title')}`}>
  <Fragment slot="banner">
    <div class="works-hero-group">
      <SectionHeader
        title={t('works.title')}
        isBanner={true}
        isHeroBanner={true}
        align="responsive"
      />
      <div class="switch-overlap">
        <ModeSwitch activeMode="motions" />
      </div>
    </div>
  </Fragment>

  <div class="spa-gallery-wrapper" id="spa-wrapper">
    <div class="spa-panel" id="panel-motions">
      <MotionGallery page={videoPage} />
    </div>
    <div class="spa-panel" id="panel-artwork">
      <ArtworkGallery page={artworkPage} />
    </div>
  </div>
</Layout>

<style>
  @import "../../../styles/works-hero.css";

  .is-hidden {
    display: none !important;
  }
</style>

<script>
  const WRAPPER_ID = "spa-wrapper";
  const PANEL_MOTIONS_ID = "panel-motions";
  const PANEL_ARTWORK_ID = "panel-artwork";
  const EASING = "cubic-bezier(0.77, 0, 0.175, 1)";
  const BAND_DUR = 400;
  const STAGGER = 60;
  const BAND_COUNT = 4;

  let currentMode: string = "motions";
  let animating = false;

  function switchTo(target: string) {
    if (animating || target === currentMode) return;
    animating = true;

    const wrapper = document.getElementById(WRAPPER_ID);
    const motions = document.getElementById(PANEL_MOTIONS_ID);
    const artwork = document.getElementById(PANEL_ARTWORK_ID);
    if (!wrapper || !motions || !artwork) { animating = false; return; }

    // Update pill UI
    const container = document.querySelector<HTMLElement>(".mode-switch-container");
    if (container) {
      container.dataset.activeMode = target;
      container.querySelectorAll<HTMLElement>(".switch-btn").forEach((b) => {
        const active = b.dataset.mode === target;
        b.classList.toggle("is-active", active);
        b.setAttribute("aria-pressed", active ? "true" : "false");
      });
    }

    // Build overlay
    const rect = wrapper.getBoundingClientRect();
    const overlay = document.createElement("div");
    overlay.style.cssText = `position:absolute;top:0;left:0;width:100%;height:${rect.height}px;z-index:100;pointer-events:none;overflow:hidden;`;

    for (let i = 0; i < BAND_COUNT; i++) {
      const band = document.createElement("div");
      band.style.cssText = `position:absolute;top:${(i / BAND_COUNT) * 100}%;left:0;width:100%;height:${100 / BAND_COUNT + 1}%;background:${i % 2 === 0 ? "#fa729d" : "#29d0f6"};transform:translateX(-110%);will-change:transform;`;
      overlay.appendChild(band);
    }

    wrapper.style.position = "relative";
    wrapper.appendChild(overlay);
    const bands = Array.from(overlay.children) as HTMLElement[];

    // Wipe in
    bands.forEach((b, i) => {
      setTimeout(() => {
        b.style.transition = `transform ${BAND_DUR}ms ${EASING}`;
        b.style.transform = "translateX(0)";
      }, i * STAGGER);
    });

    // Swap
    setTimeout(() => {
      if (target === "artwork") {
        motions.classList.add("is-hidden");
        artwork.classList.remove("is-hidden");
      } else {
        artwork.classList.add("is-hidden");
        motions.classList.remove("is-hidden");
      }
      currentMode = target;
      const basePath = window.location.pathname;
      history.pushState({ mode: target }, "", target === "motions" ? basePath : basePath + "?mode=artwork");
    }, BAND_COUNT * STAGGER + BAND_DUR * 0.6);

    // Wipe out
    const outStart = BAND_COUNT * STAGGER + BAND_DUR + 40;
    bands.forEach((b, i) => {
      setTimeout(() => { b.style.transform = "translateX(110%)"; }, outStart + i * STAGGER);
    });

    // Done
    setTimeout(() => {
      overlay.remove();
      animating = false;
    }, outStart + BAND_COUNT * STAGGER + BAND_DUR + 50);
  }

  // Attach click handlers to mode switch buttons
  function bindSwitch() {
    const container = document.querySelector<HTMLElement>(".mode-switch-container");
    if (!container) return;

    const handler = (e: Event) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-mode]");
      if (!btn || !container.contains(btn)) return;
      const mode = btn.dataset.mode;
      if (mode === "toggle") {
        switchTo(currentMode === "motions" ? "artwork" : "motions");
      } else if (mode === "motions" || mode === "artwork") {
        switchTo(mode);
      }
    };

    container.addEventListener("click", handler);
  }

  bindSwitch();

  // Hide artwork panel after custom elements have initialized
  requestAnimationFrame(() => {
    document.getElementById("panel-artwork")?.classList.add("is-hidden");
  });

  // Restore from URL
  if (new URLSearchParams(location.search).get("mode") === "artwork") {
    switchTo("artwork");
  }
</script>
