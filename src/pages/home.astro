<script>
  class HeroSlider extends HTMLElement {
    private slides: string[] = [];
    private currentIndex: number = 0;
    private realCount: number = 0;
    private isPlaying: boolean = true;
    private intervalDuration: number = 5000;
    private timer: ReturnType<typeof setTimeout> | null = null;

    private startTime: number = 0;
    private savedProgress: number = 0;
    private isDragging: boolean = false;

    private carouselTrack: HTMLElement | null = null;
    private slidesEl: NodeListOf<HTMLElement> | null = null;
    private track: HTMLElement | null = null;
    private navDots: NodeListOf<HTMLElement> | null = null;

    connectedCallback() {
      this.slides = JSON.parse(this.dataset.slides || "[]");
      if (this.slides.length === 0) return;

      this.currentIndex = 0;
      this.isPlaying = true;
      this.intervalDuration = 5000;

      // Cache DOM O(1)
      this.carouselTrack = this.querySelector<HTMLElement>(
        ".art-carousel-track",
      );
      this.slidesEl = this.querySelectorAll<HTMLElement>(".art-carousel-slide");
      this.track = this.querySelector<HTMLElement>(".kime-media-track");
      this.navDots = this.querySelectorAll<HTMLElement>(".nav-dot");
      this.realCount = this.navDots?.length || this.slides.length;

      // Infinite Loop Teleportation Logic
      this.carouselTrack?.addEventListener(
        "transitionend",
        (e: TransitionEvent) => {
          if (e.propertyName !== "transform") return;
          if (this.currentIndex >= this.realCount) {
            // Tắt hiệu ứng, giật về 0 trong tàng hình
            this.carouselTrack!.style.transition = "none";
            this.currentIndex = 0;
            this.carouselTrack!.style.setProperty("--idx", "0");
            void this.carouselTrack!.offsetWidth; // Ép reflow chặn render
            this.carouselTrack!.style.transition = ""; // Trả lại CSS cũ
            this.updateSlide(false);
          }
        },
      );

      this.setupDrag();

      this.updateSlide(true);
      this.addEventListener("click", this);
    }

    disconnectedCallback() {
      this.removeEventListener("click", this);
      this.clearTimer(false);
    }

    setupDrag() {
      if (!this.track) return;
      const scrub = (e: MouseEvent | TouchEvent | any) => {
        const rect = this.track!.getBoundingClientRect();
        const clientX = e.touches ? e.touches[0].clientX : e.clientX;
        let p = (clientX - rect.left) / rect.width;
        p = Math.max(0, Math.min(1, p));
        this.savedProgress = p;
        this.track!.style.setProperty("--track-dur", `0ms`);
        this.track!.style.setProperty("--progress", `${p * 100}%`);
      };

      this.track.addEventListener("pointerdown", (e: any) => {
        this.isDragging = true;
        this.clearTimer(true);
        scrub(e);
        this.track!.style.cursor = "grabbing";
        if (e.pointerId) this.track!.setPointerCapture(e.pointerId);
      });

      window.addEventListener("pointermove", (e: any) => {
        if (!this.isDragging) return;
        scrub(e);
      });

      window.addEventListener("pointerup", (e: any) => {
        if (!this.isDragging) return;
        this.isDragging = false;
        this.track!.style.cursor = "grab";
        if (e.pointerId && this.track!.hasPointerCapture(e.pointerId)) {
          this.track!.releasePointerCapture(e.pointerId);
        }
        if (this.isPlaying) {
          this.startTimer(this.savedProgress);
        }
      });

      // Fallback
      window.addEventListener("pointercancel", () => {
        this.isDragging = false;
      });
    }

    handleEvent(e: Event) {
      if (e.type === "click") {
        const target = e.target as HTMLElement;
        const btn = target.closest<HTMLElement>(".kime-media-btn");
        const dot = target.closest<HTMLElement>(".nav-dot");

        if (btn) {
          if (btn.classList.contains("kime-media-btn--prev")) {
            this.prevSlide();
          } else if (btn.classList.contains("kime-media-btn--next")) {
            this.nextSlide();
          } else if (btn.classList.contains("kime-media-btn--pause")) {
            this.togglePlay(btn);
          }
        } else if (dot && this.navDots) {
          const idx = Array.from(this.navDots).indexOf(dot);
          if (idx !== -1 && idx !== this.currentIndex) {
            this.currentIndex = idx;
            this.updateSlide();
          }
        }
      }
    }

    nextSlide() {
      if (this.currentIndex >= this.realCount) return; // Khoá double click khi đang lướt vào ảo ảnh
      this.currentIndex = this.currentIndex + 1;
      this.updateSlide();
    }

    prevSlide() {
      // Lướt ngược thì do chưa có ảo ảnh đầu nên đơn giản là jump thẳng về cuối mộc mạc
      if (this.currentIndex <= 0) {
        this.currentIndex = this.realCount - 1;
      } else {
        this.currentIndex--;
      }
      this.updateSlide();
    }

    togglePlay(btn: HTMLElement) {
      this.isPlaying = !this.isPlaying;
      if (this.isPlaying) {
        btn.classList.remove("paused");
        this.startTimer(this.savedProgress);
      } else {
        btn.classList.add("paused");
        this.clearTimer(true);
      }
    }

    clearTimer(saveProgress = false) {
      if (this.timer) {
        clearTimeout(this.timer);
        this.timer = null;
      }
      if (saveProgress && this.track && !this.isDragging) {
        let elapsed = Date.now() - this.startTime;
        this.savedProgress += elapsed / this.intervalDuration;
        this.savedProgress = Math.max(0, Math.min(1, this.savedProgress));
        this.track.style.setProperty("--track-dur", "0ms");
        this.track.style.setProperty(
          "--progress",
          `${this.savedProgress * 100}%`,
        );
      }
    }

    startTimer(startProgress = 0) {
      this.clearTimer(false);
      this.savedProgress = startProgress;
      if (!this.isPlaying || !this.track) return;

      this.startTime = Date.now();
      const remainingTime = this.intervalDuration * (1 - startProgress);

      this.track.style.setProperty("--track-dur", "0ms");
      this.track.style.setProperty("--progress", `${startProgress * 100}%`);

      void this.track.offsetWidth;

      this.track.style.setProperty("--track-dur", `${remainingTime}ms`);
      this.track.style.setProperty("--progress", "100%");

      this.timer = setTimeout(() => {
        this.nextSlide();
      }, remainingTime);
    }

    updateSlide(init: boolean = false) {
      const visualIndex = this.currentIndex % this.realCount;

      if (this.navDots) {
        this.navDots.forEach((dot, idx) => {
          dot.classList.toggle("nav-dot--active", idx === visualIndex);
        });
      }

      if (this.carouselTrack) {
        this.carouselTrack.style.setProperty(
          "--idx",
          this.currentIndex.toString(),
        );
      }
      if (this.slidesEl) {
        this.slidesEl.forEach((el, idx) => {
          // Ép cả ảo ảnh (Clone) và bản thể gốc cùng sáng lên để lúc giật Teleport màn hình đéo bị chớp (flash) đen
          el.classList.toggle(
            "is-active",
            idx === this.currentIndex || idx === visualIndex,
          );
        });
      }

      if (this.isPlaying) {
        this.startTimer(0);
      } else {
        this.savedProgress = 0;
        if (this.track) {
          this.track.style.setProperty("--track-dur", "0ms");
          this.track.style.setProperty("--progress", "0%");
        }
      }
    }
  }

  if (!customElements.get("hero-slider")) {
    customElements.define("hero-slider", HeroSlider);
  }
</script>

<script>
  const initCopyEngine = () => {
    const copyBtns = document.querySelectorAll<HTMLButtonElement>(".btn-copy");

    if (!copyBtns.length) return;

    copyBtns.forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        e.preventDefault();

        const text = btn.dataset.copyText;

        if (!text) {
          console.error("Clipboard Error: Missing data-copy-text");
          return;
        }

        try {
          if (!navigator.clipboard) {
            throw new Error(
              "Clipboard API bị chặn. Phải chạy trên HTTPS hoặc Localhost.",
            );
          }

          await navigator.clipboard.writeText(text);

          const originalHtml = btn.innerHTML;
          btn.innerHTML = `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>`;

          setTimeout(() => {
            btn.innerHTML = originalHtml;
          }, 1500);
        } catch (err) {
          console.error("Failed to write to Memory/Clipboard:", err);
        }
      });
    });
  };

  initCopyEngine();

  document.addEventListener("astro:page-load", initCopyEngine);
</script>
