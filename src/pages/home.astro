.25 149.398C236.828 152.961 236.469 155.391 236.172 156.688C235.891 157.984 235.414 159.055 234.742 159.898C234.07 160.742 233.133 161.359 231.93 161.75C230.742 162.156 228.836 162.359 226.211 162.359H220.469V157.391C221.938 157.391 222.883 157.32 223.305 157.18C223.727 157.023 223.938 156.688 223.938 156.172C223.938 155.922 223.742 154.836 223.352 152.914L218.172 126.898H226.773L229.867 147.875L231.367 126.898H239.969Z" class="fs-play-paths" />
                          <rect x="317.323" y="166.107" width="33.7807" height="33.7807" transform="rotate(-135 317.323 166.107)" class="fs-play-paths" />
