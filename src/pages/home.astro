            </button>
          </div>

          <!-- Facebook -->
          <div class="social-pill-wrapper">
            <a
              href={fbLink}
              target="_blank"
              rel="noopener noreferrer"
              class="social-pill__link"
              aria-label="Kimeyu Facebook"
            >
              <div class="social-pill__icon">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103v3.328h-1.011c-2.122 0-2.56.778-2.56 2.47v1.657h3.646l-.508 3.666h-3.138v7.98h-3.75z"
