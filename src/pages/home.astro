---
import Layout from "../layouts/Layout.astro";
import KimeSplash from "../components/KimeSplash.astro";
import CyberRibbon from "../components/CyberRibbon.astro";
import PageDecorBanner from "../components/PageDecorBanner.astro";
import KimeyuIcon from "../components/icons/KimeyuIcon.astro";
import { fetchVideos, fetchArtworks, fetchSiteProfile } from "../lib/hygraph";

// FETCH HERO SLIDER DATA
const [allVideos, allArtworks, profileData] = await Promise.all([
  fetchVideos(),
  fetchArtworks(),
  fetchSiteProfile().catch(() => null),
]);

// Social Links Fallbacks
const discordLink = profileData?.linkDiscord || "https://discord.com/users/683574461147906078";
const discordHandle = profileData?.handleDiscord || "kimeyu_39";

const xLink = profileData?.linkX || "https://twitter.com/Kimeru2001";
const xHandle = profileData?.handleX || "@Kimeru2001";

const fbLink = profileData?.linkFacebook || "https://facebook.com/kimerukirisu/";
const fbHandle = profileData?.handleFacebook || "facebook.com/kimerukirisu/";

const emailLink = profileData?.linkEmail || "mailto:kimeyukawa@gmail.com";
const emailHandle = profileData?.handleEmail || "kimeyukawa@gmail.com";

// Extract newest item per category (Zero bloat: only storing strings)
const vMusic = allVideos.find((v) => v.category?.name?.includes("MusicVideos"));
const vDebut = allVideos.find((v) => v.category?.name?.includes("Debut"));
const aIllust = allArtworks.find((a) => a.category?.name === "Illustration");

const heroSlides = [
  vMusic
    ? {
        url:
          vMusic.imageEmbed?.[0]?.heroUrl ||
          vMusic.thumbnail?.heroUrl ||
          vMusic.thumbnail?.fullUrl ||
          vMusic.thumbnail?.url,
        link: vMusic.linkOriginal || `/work/motions/${vMusic.slug}`,
        target: "_blank",
      }
    : null,
  vDebut
    ? {
        url:
          vDebut.imageEmbed?.[0]?.heroUrl ||
          vDebut.thumbnail?.heroUrl ||
          vDebut.thumbnail?.fullUrl ||
          vDebut.thumbnail?.url,
        link: vDebut.linkOriginal || `/work/motions/${vDebut.slug}`,
        target: "_blank",
      }
    : null,
  aIllust
    ? {
        url:
          aIllust.image?.heroUrl ||
          aIllust.image?.fullUrl ||
          aIllust.image?.url,
        link: aIllust.linkPixiv || `/work/?mode=artwork`,
        target: "_blank",
      }
    : null,
].filter((s): s is { url: string; link: string; target: string } =>
  Boolean(s && s.url),
);

// Extract FEATURED videos
const featuredVideos = allVideos.filter((v) => v.isFeatured).slice(0, 6);
---

<Layout title="kimeyu.work">
  <div class="contact-page-wrapper">
    <KimeSplash />

    <!-- TOP RIBBON (ASCII generated SVG) -->
    <CyberRibbon />

    <div class="decor-ribbon" aria-hidden="true" style="margin-bottom: 2rem;">
      <div class="film-strip-bg">
        <div class="banner-strip" style="transform: translateY(-50%);"></div>
      </div>
    </div>

    <!-- Kimeyu Core Slogan -->
    <section class="contact-quote-block" aria-label="Kimeyu Slogan">
      <div class="quote-wrapper">
        <h2 class="quote-text">
          <span class="quote-line-wrap">
            <span class="quote-line"
              >BUILT ON <span class="text-cyan">RHYTHM</span></span
            >
            <span class="qr-band qr-band--pink" aria-hidden="true"></span>
          </span>
          <span class="quote-line-wrap">
            <span class="quote-line"
              >DRIVEN BY <span class="text-pink">PRECISION</span></span
            >
            <span class="qr-band qr-band--cyan" aria-hidden="true"></span>
          </span>
        </h2>
      </div>
    </section>

    <!-- PICK UP WORKS BANNER -->
    <div class="decor-ribbon pickup-works-ribbon">
      <div class="ribbon-pickup-label">
        <span class="pickup-en">PICK-UP WORKS</span>
        <span class="pickup-jp">ピックアップ作品</span>
      </div>
      <nav class="ribbon-nav-dots" aria-label="Page Navigation">
        <button class="nav-dot nav-dot--active" aria-label="Section 1"></button>
        <button class="nav-dot" aria-label="Section 2"></button>
        <button class="nav-dot" aria-label="Section 3"></button>
        <button class="nav-dot" aria-label="Section 4"></button>
        <button class="nav-dot" aria-label="Section 5"></button>
      </nav>
      <div class="film-strip-bg" aria-hidden="true">
        <div class="banner-strip banner-strip--inverted"></div>
      </div>
    </div>

    <!-- FEATURED SECTION (nim.design style: fixed viewport + translateY) -->
    <section class="featured-works-section" aria-label="Featured Works" id="featured-works-section">
      <!-- This viewport is position:sticky and clips the slides -->
      <div class="fs-viewport">
        <!-- translateY'd by JS -->
        <div class="fs-inner" id="fs-inner">
          {
            featuredVideos.slice(0, 3).map((video, index) => (
              <article class="featured-sticky-card">
                
                <div class="fs-card-inner">
                  <!-- Watermark -->
                  <div class="fs-bg-watermark" aria-hidden="true">FEATURED</div>

                  <!-- Top Left: Tags -->
                  <div class="fs-top-left">
                    <div class="fs-tags">
                      <div class="fs-tag-motion">
                        <span class="fs-tag-text">{video.category?.name?.toUpperCase() || "MOTION GRAPHICS"}</span>
                        <div class="fs-checker-icon"></div>
                      </div>
                      <div class="fs-tag-status">
                        {video.category?.visibility === "Private" ? "Private" : "Public"}
                      </div>
                    </div>
                  </div>

                  <!-- Center/Right: Video -->
                  <div class="fs-video-area">
                    <a href={`/work/motions/${video.slug}`} class="fs-thumb-link" aria-label={`Watch ${video.title}`}>
                      <div class="fs-thumb-frame">
                        <img src={video.thumbnail.url} alt={video.title} loading="lazy" class="fs-thumb-img" />
                      </div>
                    </a>
                  </div>

                  <!-- Bottom Left: Number & Titles & Play -->
                  <div class="fs-bottom-left">
                    <div class="fs-number"><span class="mask-text">0{index + 1}</span></div>
                    <div class="fs-title-play-row">
                      <div class="fs-titles">
                        <h4 class="fs-artist"><span class="mask-text">{video.nameArtist}</span></h4>
                        <h3 class="fs-title"><span class="mask-text decode-target" data-decode-text={video.title}>{video.title}</span></h3>
                      </div>
                      <a href={`/work/motions/${video.slug}`} class="fs-play-link" aria-label={`Watch ${video.title}`}>
                        {index === 1 ? (
