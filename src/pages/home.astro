    content: "";
    position: absolute;
    --q-w: clamp(10px, 2.5vw, 20px);
    --q-h: clamp(28px, 5vw, 45px);
    --q-gap: calc(var(--q-w) * 1.5);
    width: var(--q-w);
    height: var(--q-h);
    transform: skewX(-15deg);
  }

  .quote-wrapper::before {
    top: 0;
    left: 0;
    background-color: var(--color-secondary-bright);
    box-shadow: var(--q-gap) 0 0 var(--color-secondary-bright);
  }
  .quote-wrapper::after {
    bottom: -15%;
    right: var(--q-gap);
    background-color: var(--color-primary);
    box-shadow: var(--q-gap) 0 0 var(--color-primary);
  }

  .quote-text {
    font-size: clamp(1.4rem, 4.5vw, 3.8rem);
    font-weight: 900;
    font-family: var(--font-sans);
    color: var(--color-secondary-darker);
    text-align: center;
    line-height: 1.15;
    margin: 0;
    display: flex;
    flex-direction: column;
    letter-spacing: -0.01em;
  }
  .quote-text .text-cyan {
    color: var(--color-secondary-bright);
  }
  .quote-text .text-pink {
    color: var(--color-primary);
  }

  /* ==============================================
     INVERTED BANNER STRIP
     ============================================== */
  .contact-bottom-ribbon {
    --b-gap: clamp(4px, 1vw, 12px);
    --b-h-top: clamp(10px, 3vw, 28px);
    --b-h-bottom: clamp(20px, 5vw, 48px);
    --b-pad: clamp(12px, 2vw, 20px);
    --b-total-h: calc(
      var(--b-h-top) + var(--b-h-bottom) + var(--b-gap) + 2 * var(--b-pad)
    );
    --safe-edge: clamp(var(--spacing-6), 5vw, var(--spacing-12));

    position: relative;
    width: 100%;
    height: var(--b-total-h);
    margin-top: var(--spacing-8);
    overflow: hidden;
  }

  @media (min-width: 80rem) {
    .contact-bottom-ribbon {
      --safe-edge: calc(50vw - 40rem + var(--spacing-12));
    }
  }
  @media (min-width: 1024px) {
    .contact-bottom-ribbon {
      margin-top: 0;
    }
  }

  .pickup-works-ribbon {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--safe-edge);
    overflow: hidden;
  }

  .film-strip-bg {
    position: absolute;
    inset: 0 -10vw;
    z-index: 1;
    pointer-events: none;
  }

  .banner-strip {
    --gap: var(--b-gap);
    --h-top: var(--b-h-top);
    --h-bottom: var(--b-h-bottom);
    --pad: var(--b-pad);
    --sq-w: calc(var(--h-top) + var(--h-bottom) + var(--gap));
    --logo-w: calc(var(--h-bottom) * 4.8879);
    --margin-gap: clamp(8px, 4vw, 64px);
    --tile-w: calc(
      2 * var(--pad) + var(--sq-w) + var(--gap) + var(--logo-w) +
        var(--margin-gap)
    );
    --tile-h: calc(
      2 * var(--pad) + var(--h-top) + var(--gap) + var(--h-bottom)
    );

    position: absolute;
    top: 50%;
    left: -10vw;
    width: 200vw;
    height: var(--tile-h);
    transform-origin: 50vw center;

    background-color: var(--color-secondary-light);
    border-top: var(--border-width-md, 2px) solid var(--base-white);
    border-bottom: var(--border-width-md, 2px) solid var(--base-white);
    box-shadow: 0 4px 4px rgba(0, 0, 0, 0.12);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    -webkit-transform-style: preserve-3d;
    transform-style: preserve-3d;

    background-image: url("/patterns/kimeyu-tile-cyan.svg");
    background-size: var(--tile-w) var(--tile-h);
    background-repeat: repeat-x;
    background-position: 0 center;
  }

  .banner-strip--inverted {
    transform: translateY(-50%) rotate(0) scaleY(-1) translateZ(0);
    z-index: 1;
  }

  /* ==============================================
     PICK-UP WORKS LABEL
     ============================================== */
  .ribbon-pickup-label {
    position: relative;
    z-index: 5;
    background-color: var(--base-white);
    border: clamp(2px, 0.4vw, 3px) solid var(--color-secondary-darker);
    padding: clamp(4px, 1vw, 10px) clamp(6px, 1.5vw, 24px);
    display: flex;
    align-items: baseline;
    gap: clamp(2px, 0.8vw, var(--spacing-3));
    white-space: nowrap;
    flex-shrink: 1;
    min-width: 0;
    overflow: hidden;
  }
  .pickup-en {
    font-size: clamp(0.55rem, 1.5vw, 1rem);
    font-weight: 900;
    color: var(--color-secondary-darker);
    letter-spacing: 0.5px;
  }
  .pickup-jp {
    font-size: clamp(0.45rem, 1.2vw, 0.8rem);
    font-weight: 800;
    color: var(--color-secondary-darker);
  }

  /* ==============================================
     NAVIGATION DOTS
     ============================================== */
  .ribbon-nav-dots {
    --dot-size: max(calc(var(--b-total-h) * 0.17), 13px);
    --dot-gap: max(calc(var(--b-total-h) * 0.095), 6px);
    --dot-border: clamp(2px, 0.4vw, 3px);
    --dot-pad: max(calc(var(--b-total-h) * 0.08), 6px);
    --checker-cell: calc((var(--dot-size) + 2 * var(--dot-pad)) / 3);
    --grid-w: calc(var(--checker-cell) * 7);
    --gap-to-grid: max(calc(var(--b-total-h) * 0.185), 14px);
    --grid-pad-right: max(calc(var(--b-total-h) * 0.14), 10px);

    position: absolute;
    left: var(--safe-edge);
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    gap: var(--dot-gap);

    padding: var(--dot-pad);
    border: var(--dot-border) solid var(--color-secondary-darker);
    border-radius: calc(var(--dot-size) / 2 + var(--dot-pad));
    padding-right: calc(
      var(--gap-to-grid) + var(--grid-w) + var(--grid-pad-right)
    );
    overflow: hidden;
    isolation: isolate;
  }

  @media (min-width: 1024px) {
    .ribbon-nav-dots {
      left: clamp(var(--spacing-12), 10vw, 15vw);
    }
  }
  @media (min-width: 80rem) {
    .ribbon-nav-dots {
      left: calc(50vw - 40rem + 15vw);
    }
  }

  .pickup-works-ribbon .ribbon-nav-dots {
    position: relative;
    left: auto;
    top: auto;
    transform: none;
    flex-shrink: 0;
    transform: scale(clamp(0.7, calc(0.5 + 0.3 * (100vw - 320px) / 400), 1));
    transform-origin: right center;
  }

  @media (max-width: 768px) {
    .pickup-works-ribbon .ribbon-nav-dots {
      --grid-w: calc(var(--checker-cell) * 3);
    }
  }

  .ribbon-nav-dots::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image:
      linear-gradient(var(--base-white), var(--base-white)),
      linear-gradient(var(--base-white), var(--base-white));
    background-position:
      left center,
      right center;
    background-size:
      calc(100% - var(--grid-w) - var(--grid-pad-right)) 100%,
      var(--grid-pad-right) 100%;
    background-repeat: no-repeat;
  }

  .ribbon-nav-dots::after {
    content: "";
    position: absolute;
    right: var(--grid-pad-right);
    top: 0;
    width: var(--grid-w);
    height: 100%;
    z-index: -1;
    background-image: conic-gradient(
      var(--base-white) 90deg,
      transparent 90deg 180deg,
      var(--base-white) 180deg 270deg,
      transparent 270deg
    );
    background-size: calc(var(--checker-cell) * 2) calc(var(--checker-cell) * 2);
    background-position: 0 0;
  }

  .nav-dot {
    width: var(--dot-size);
    height: var(--dot-size);
    border-radius: 50%;
    border: var(--dot-border) solid var(--color-secondary-darker);
    background-color: var(--color-secondary-light);
    padding: 0;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }
  .nav-dot:hover {
    transform: scale(1.15);
  }
  .nav-dot--active {
    background-color: var(--color-primary);
    border-color: var(--color-secondary-darker);
  }

  /* ==============================================
     FEATURED WORKS SECTION
     ============================================== */
  .featured-works-section {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-bottom: var(--spacing-12);
    z-index: 10;
  }

  .featured-header {
    width: 100%;
    background-color: var(--color-primary);
    padding: var(--spacing-8) 0 calc(var(--spacing-16) + 4vw) 0;
    display: flex;
    justify-content: center;
  }

  .featured-title {
    font-family: var(--font-sans);
    font-size: clamp(4rem, 15vw, 10rem);
    font-weight: 900;
    color: var(--base-gray-50);
    margin: 0;
    line-height: 0.8;
    letter-spacing: -0.02em;
  }

  .featured-cards-container {
    margin-top: -8vw;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 340px), 1fr));
    justify-items: center;
    gap: clamp(var(--spacing-6), 6vw, var(--spacing-16));
    width: 100%;
    max-width: 1240px;
    padding: 0 clamp(16px, 4vw, 40px);
    position: relative;
    z-index: 2;
  }

  @media (max-width: 1023px) {
    .featured-card:nth-child(n + 4) {
      display: none !important;
    }
  }
  @media (max-width: 400px) {
    .featured-cards-container {
      margin-top: -12vw;
    }
  }
  @media (min-width: 768px) {
    .featured-cards-container {
      margin-top: -70px;
    }
  }

  .featured-card {
    --c-border: 3px solid var(--color-secondary-darker);
    --c-pink-line: 4px solid var(--color-primary-light);
    display: flex;
    flex-direction: column;
    width: clamp(280px, 85vw, 360px);
    position: relative;
    align-items: center;
  }

  .card-thumb {
    width: calc(100% - 40px);
    aspect-ratio: 16/10;
    background-color: var(--base-white);
    border: var(--c-border);
    border-bottom: var(--c-pink-line);
    position: relative;
    z-index: 2;
  }

  .card-thumb::before {
    content: "";
    position: absolute;
    top: 10px;
    left: calc(100% + 10px);
    --decor-cell: 8px;
    --blocks-x: 3;
    --blocks-y: 3;
    width: calc(var(--decor-cell) * var(--blocks-x));
    height: calc(var(--decor-cell) * var(--blocks-y));
    background-color: var(--color-secondary-light);
  }

  .card-thumb::after {
    content: "";
    position: absolute;
    --decor-cell: 8px;
    top: calc(10px + var(--decor-cell) * 3.5);
    left: calc(100% + 10px);
    --blocks-x: 3;
    --blocks-y: 5;
    width: calc(var(--decor-cell) * var(--blocks-x));
    aspect-ratio: var(--blocks-x) / var(--blocks-y);
    background: repeating-conic-gradient(
        transparent 0 90deg,
        var(--color-secondary-light) 0 180deg
      )
      0 0 / calc((100% + 0.5px) / var(--blocks-x) * 2)
      calc((100% + 0.5px) / var(--blocks-y) * 2);
  }

  .card-info {
    width: 100%;
    background-color: var(--color-secondary-light);
    border-radius: 94.5px 20px 20px 0px;
    padding: calc(20% + 12px) 24px 24px 24px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-top: -20%;
    z-index: 1;
  }

  .card-info__text {
    display: flex;
    flex-direction: column;
    min-width: 0;
    padding-right: 16px;
  }
  .card-info__text .card-title {
    font-size: clamp(1rem, 5vw, 1.3rem);
    font-weight: 900;
    color: var(--color-secondary-darker);
    line-height: 1.1;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .card-info__text .card-sub {
    font-size: clamp(0.75rem, 3.5vw, 0.85rem);
    font-weight: 700;
    color: var(--color-secondary-darker);
    margin: 0;
  }

  .card-play-btn {
    width: 0;
    height: 0;
    border-top: 15px solid transparent;
    border-bottom: 15px solid transparent;
    border-left: 20px solid var(--base-white);
    transform: translateX(-10px);
  }

  .card-tags {
    display: flex;
    align-items: stretch;
    margin-top: 12px;
    width: 100%;
  }
  .tag-cat {
    --tag-color: var(--color-primary);
    background-color: var(--tag-color);
    color: var(--base-white);
    font-size: 14px;
    font-weight: 800;
    padding: 0 16px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    position: relative;
    white-space: nowrap;
    margin-right: 50px;
  }
  .tag-cat::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    right: -34px;
    width: 34px;
    background-image:
      linear-gradient(var(--tag-color), var(--tag-color)),
      linear-gradient(var(--tag-color), var(--tag-color)),
      linear-gradient(var(--tag-color), var(--tag-color)),
      linear-gradient(var(--tag-color), var(--tag-color));
    background-size: 33.5% 33.5%;
    background-position:
      0% 0%,
      0% 100%,
      50% 50%,
      100% 0%;
    background-repeat: no-repeat;
  }
  .tag-status {
    height: 34px;
    background-color: var(--color-secondary-light);
    color: var(--color-secondary-darker);
    border: 2px solid var(--color-secondary-darker);
    font-size: 14px;
    font-weight: 800;
    padding: 0 16px;
    display: inline-flex;
    align-items: center;
    margin-left: 0;
  }

  .card-badge {
    position: absolute;
    right: -15px;
    top: -15px;
    background-color: var(--base-white);
    border: 3px solid var(--color-secondary-darker);
    border-radius: var(--radius-pill);
    padding: 4px 14px;
    color: var(--color-primary-light);
    font-weight: 900;
    font-size: 0.8rem;
    z-index: 10;
  }
  .card-badge::after {
    content: "";
    position: absolute;
    bottom: -7px;
    left: 20%;
    width: 12px;
    height: 12px;
    background-color: var(--base-white);
    border-bottom: 3px solid var(--color-secondary-darker);
    border-left: 3px solid var(--color-secondary-darker);
    transform: rotate(-45deg);
  }

  .featured-footer-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 1240px;
    padding: 0 clamp(16px, 4vw, 40px);
    margin-top: var(--spacing-12);
  }
  .featured-pagination {
    display: flex;
    gap: var(--spacing-3);
    margin-bottom: var(--spacing-10);
  }

  @media (min-width: 768px) {
    .featured-footer-row {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      margin-top: var(--spacing-16);
    }
    .featured-pagination {
      grid-column: 2;
      margin-bottom: 0;
    }
    .featured-footer-row > .page-decor-banner {
      grid-column: 3;
      justify-self: end;
      margin-bottom: 0;
    }
  }

  @media (min-width: 1024px) {
    .featured-footer-row
      > .page-decor-banner.page-decor-banner--compact.page-decor-banner--checker-both {
      margin-inline: 0;
      margin-left: auto;
      margin-right: calc(-1 * clamp(16px, 4vw, 40px));
    }
  }

  .featured-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid var(--color-primary-light);
    background-color: transparent;
    padding: 0;
    cursor: pointer;
  }
  .featured-dot--active {
    background-color: var(--color-primary-light);
  }

  /* =========================================
     CONTACT ENTRY SECTION
     ========================================= */
  .contact-entry-section {
    width: 100%;
    background-color: var(--color-primary);
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 5;
  }

  .contact-entry-ribbon {
    --sq: clamp(30px, 4vw, 44px);
    width: 100%;
    height: var(--sq);
    background-color: var(--color-primary);

    --c-cyan: var(--color-secondary-light);
    --c-pink: var(--color-primary);
    --c-border: var(--color-secondary-darker);
    --c-white: var(--base-white);

    --cell: calc(var(--sq) / 3);
    --w-cell-p: calc(100% / 6);
    --r-in: calc(var(--sq) * 0.25);
    --r-out: calc(var(--sq) * 0.36);

    --dot-c: radial-gradient(
      circle,
      var(--c-cyan) 0,
      var(--c-cyan) var(--r-in),
      var(--c-border) calc(var(--r-in) + 0.5px),
      var(--c-border) var(--r-out),
      transparent calc(var(--r-out) + 0.5px)
    );
    --dot-p: radial-gradient(
      circle,
      var(--c-pink) 0,
      var(--c-pink) var(--r-in),
      var(--c-border) calc(var(--r-in) + 0.5px),
      var(--c-border) var(--r-out),
      transparent calc(var(--r-out) + 0.5px)
    );
    --w-blk: linear-gradient(var(--c-white), var(--c-white));
    --caro-odd: repeating-linear-gradient(
      90deg,
      var(--c-white) 0,
      var(--c-white) var(--w-cell-p),
      transparent var(--w-cell-p),
      transparent calc(var(--w-cell-p) * 2)
    );
    --caro-even: repeating-linear-gradient(
      90deg,
      transparent 0,
      transparent var(--w-cell-p),
      var(--c-white) var(--w-cell-p),
      var(--c-white) calc(var(--w-cell-p) * 2)
    );

    background-image:
      var(--w-blk), var(--dot-p), var(--dot-c), var(--dot-c), var(--dot-c),
      var(--dot-c), var(--w-blk), var(--caro-odd), var(--caro-even),
      var(--caro-odd), var(--w-blk);

    background-size:
      var(--sq) 100%,
      var(--sq) var(--sq),
      var(--sq) var(--sq),
      var(--sq) var(--sq),
      var(--sq) var(--sq),
      var(--sq) var(--sq),
      calc(100% - calc(var(--sq) * 3)) 100%,
      calc(var(--sq) * 2) var(--cell),
      calc(var(--sq) * 2) var(--cell),
      calc(var(--sq) * 2) var(--cell),
      var(--sq) 100%;

    background-position:
      100% 0,
      calc(100% - calc(var(--sq) * 1)) 0,
      calc(100% - calc(var(--sq) * 2)) 0,
      calc(100% - calc(var(--sq) * 3)) 0,
      calc(100% - calc(var(--sq) * 4)) 0,
      calc(100% - calc(var(--sq) * 5)) 0,
      calc(var(--sq) * 3) 0,
      calc(var(--sq) * 1) calc(var(--cell) * 2),
      calc(var(--sq) * 1) var(--cell),
      calc(var(--sq) * 1) 0,
      0 0;

    background-repeat: no-repeat;
  }

  .contact-huge-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: var(--base-white);
    width: 100%;
    margin-bottom: -0.1em;
    overflow: hidden;
    padding-top: var(--spacing-4);
  }

  @media (min-width: 1024px) {
    .contact-huge-row {
      margin-bottom: 0.4em;
    }
  }

  .contact-huge-title {
    font-size: clamp(48px, 10vw, 140px);
    font-weight: 900;
    color: var(--color-primary);
    line-height: 0.85;
    padding-left: clamp(1px, 1vw, 40px);
    flex-shrink: 1;
    min-width: 0;
  }

  .contact-huge-right {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--sym-margin, 0.5rem);
    flex-shrink: 0;
    padding-right: 0;
    max-width: calc(50vw - 15px);
    overflow-x: clip;
    overflow-y: visible;
    pointer-events: none;
    --r-thickness: 5px;
    --checker-cell: 20px;
    --checker-w: calc(var(--checker-cell) * 1.5);
    --checker-h: calc(var(--checker-cell) * 1.5);
    --symbol-h: 30px;
    --block-ratio: 1.8;
  }

  .cht-right-top {
    --symbol-size: clamp(24px, 5vw, 50px);
    --cross-length: clamp(22px, 4.5vw, 46px);
    --symbol-thickness: clamp(5px, 0.8vw, 10px);
    --border-cross: clamp(4px, 0.7vw, 10px);
    --checker-h: var(--symbol-size);
    --checker-cell: calc(var(--checker-h) / 1.5);
    --checker-w: calc(var(--checker-cell) * 1.5);
    --top-gap: 8px;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--top-gap);
  }

  .cht-symbol-circle {
    width: var(--symbol-size);
    height: var(--symbol-size);
    border: var(--symbol-thickness) solid var(--color-primary);
    border-radius: var(--radius-pill);
    flex-shrink: 0;
    order: 1;
  }
  .cht-symbol-cross {
    width: var(--symbol-size);
    height: var(--symbol-size);
    position: relative;
    flex-shrink: 0;
    order: 2;
  }
  .cht-symbol-cross::before,
  .cht-symbol-cross::after {
    content: "";
    position: absolute;
    width: var(--cross-length);
    height: var(--symbol-thickness);
    background-color: var(--color-primary);
    border: var(--border-cross) solid var(--color-primary);
    top: 50%;
    left: 50%;
  }
  .cht-symbol-cross::before {
    transform: translate(-50%, -50%) rotate(45deg);
  }
  .cht-symbol-cross::after {
