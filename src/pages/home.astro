<script>
  const initCopyEngine = () => {
    const copyBtns = document.querySelectorAll<HTMLButtonElement>(".btn-copy");

    if (!copyBtns.length) return;

    copyBtns.forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        e.preventDefault();

        const text = btn.dataset.copyText;

        if (!text) {
          console.error("Clipboard Error: Missing data-copy-text");
          return;
        }

        try {
          if (!navigator.clipboard) {
            throw new Error(
              "Clipboard API bị chặn. Phải chạy trên HTTPS hoặc Localhost.",
            );
          }

          await navigator.clipboard.writeText(text);

          const originalHtml = btn.innerHTML;
          btn.innerHTML = `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>`;

          setTimeout(() => {
            btn.innerHTML = originalHtml;
          }, 1500);
        } catch (err) {
          console.error("Failed to write to Memory/Clipboard:", err);
        }
      });
    });
  };

  initCopyEngine();

  document.addEventListener("astro:page-load", initCopyEngine);

  // --- QUOTE REVEAL ON SCROLL ---
  const initQuoteReveal = () => {
    const section = document.querySelector<HTMLElement>(".contact-quote-block");
    if (!section) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            section.classList.add("is-revealed");
            observer.disconnect();
          }
        }
      },
      { threshold: 0.4 },
    );

    observer.observe(section);
  };

  initQuoteReveal();
  document.addEventListener("astro:page-load", initQuoteReveal);

  // Featured section: nim.design style — intercept wheel, translateY the fs-inner container
  const initFeaturedSnap = () => {
    const section = document.getElementById('featured-works-section');
    const inner = document.getElementById('fs-inner');
    if (!section || !inner) return;

    const SLIDE_COUNT = inner.children.length; // 3 cards + 1 other-works
    const ANIM_DURATION = 700;
    const DELTA_THRESHOLD = 60;
    let currentSlide = 0;
    let isAnimating = false;
    let wheelDelta = 0;

    const goTo = (index) => {
      currentSlide = Math.max(0, Math.min(SLIDE_COUNT - 1, index));
      inner.style.transform = `translateY(${-currentSlide * 100}%)`;
      isAnimating = true;
      setTimeout(() => { isAnimating = false; }, ANIM_DURATION);
    };

    const isFeaturedActive = () => {
      const r = section.getBoundingClientRect();
      // section's sticky viewport is pinned to top
      return r.top <= 1 && r.bottom >= window.innerHeight - 1;
    };

    const onWheel = (e) => {
      if (!isFeaturedActive()) return;
      // Allow exit: on last slide going down, or first slide going up
      if (currentSlide === SLIDE_COUNT - 1 && e.deltaY > 0) return;
      if (currentSlide === 0 && e.deltaY < 0) return;

      e.preventDefault();
      if (isAnimating) return;

      wheelDelta += e.deltaY;
      if (Math.abs(wheelDelta) < DELTA_THRESHOLD) return;
      const dir = wheelDelta > 0 ? 1 : -1;
      wheelDelta = 0;
      goTo(currentSlide + dir);
    };

    // Touch
    let touchY = 0;
    const onTouchStart = (e) => { touchY = e.touches[0].clientY; };
    const onTouchEnd = (e) => {
      if (!isFeaturedActive()) return;
      const dy = touchY - e.changedTouches[0].clientY;
      if (Math.abs(dy) < 30 || isAnimating) return;
      const dir = dy > 0 ? 1 : -1;
      if (currentSlide === SLIDE_COUNT - 1 && dir > 0) return;
      if (currentSlide === 0 && dir < 0) return;
      goTo(currentSlide + dir);
    };

    // Reset when scrolled back above the section
    const onScroll = () => {
      if (section.getBoundingClientRect().top > 10) {
        currentSlide = 0;
        inner.style.transform = 'translateY(0)';
      }
    };

    window.addEventListener('wheel', onWheel, { passive: false });
    window.addEventListener('touchstart', onTouchStart, { passive: true });
    window.addEventListener('touchend', onTouchEnd, { passive: true });
