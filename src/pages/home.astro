                          <path fill-rule="evenodd" clip-rule="evenodd" d="M273.905 133.146L265.229 141.822L273.905 150.498L277.795 150.498L269.119 141.822L277.795 133.146L273.905 133.146Z" class="fs-play-paths" />
                        </svg>
                      </a>
                    </div>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- OTHER WORKS BANNER -->
    <a href="/work/" class="ow-section" aria-label="View Other Works">
      <div class="ow-new-banner">
        <svg width="931" height="125" viewBox="0 0 931 125" class="ow-new-svg" fill="none" xmlns="http://www.w3.org/2000/svg">
