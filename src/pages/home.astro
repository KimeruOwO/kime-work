---
import Layout from "../layouts/Layout.astro";
import PageDecorBanner from "../components/PageDecorBanner.astro";
import KimeyuIcon from "../components/icons/KimeyuIcon.astro";
import { fetchVideos, fetchArtworks } from "../lib/hygraph";

// FETCH HERO SLIDER DATA
const [allVideos, allArtworks] = await Promise.all([
  fetchVideos(),
  fetchArtworks(),
]);

// Extract newest item per category (Zero bloat: only storing strings)
const vMusic = allVideos.find((v) => v.category?.name?.includes("MusicVideos"));
const vDebut = allVideos.find((v) => v.category?.name?.includes("Debut"));
const aIllust = allArtworks.find((a) => a.category?.name === "Illustration");

const heroSlides = [
  vMusic
    ? {
        url:
          vMusic.imageEmbed?.[0]?.heroUrl ||
          vMusic.thumbnail?.heroUrl ||
          vMusic.thumbnail?.fullUrl ||
          vMusic.thumbnail?.url,
        link: vMusic.linkOriginal || `/work/motions/${vMusic.slug}`,
        target: "_blank",
      }
    : null,
  vDebut
    ? {
        url:
          vDebut.imageEmbed?.[0]?.heroUrl ||
          vDebut.thumbnail?.heroUrl ||
          vDebut.thumbnail?.fullUrl ||
          vDebut.thumbnail?.url,
        link: vDebut.linkOriginal || `/work/motions/${vDebut.slug}`,
        target: "_blank",
      }
    : null,
  aIllust
    ? {
        url: aIllust.image?.heroUrl || aIllust.image?.fullUrl || aIllust.image?.url,
        link: `/work/illustrations/${aIllust.slug}`,
        target: "_self",
      }
    : null,
].filter((s): s is { url: string; link: string; target: string } => Boolean(s && s.url));

// Extract FEATURED videos
const featuredVideos = allVideos.filter((v) => v.isFeatured).slice(0, 6);
---

<Layout
  title="Kime Work - Home"
  description="Get in touch with Kimeyu for motion graphics, music video, illustration, and design commissions."
>
  <div class="contact-page-wrapper">
    <header class="art-header">
      <div class="art-header__left">
        <h1 class="art-header__logo">
          <span class="sr-only">Kimeyu Art Direction</span>
          <svg
            class="art-header__kimeyu-icon"
            viewBox="0 0 2302.5 471.06"
            aria-hidden="true"
          >
            <use href="#kimeyu-logo"></use>
          </svg>
        </h1>
      </div>

      <div class="art-header__right">
        <ul class="art-header__text">
          <li>// ART DIRECTION</li>
          <li>// MOTION GRAPHICS</li>
          <li>// ILLUSTRATION</li>
        </ul>
      </div>
    </header>

    <hero-slider data-slides={JSON.stringify(heroSlides)}>
      <section class="contact-hero-showcase">
        <div class="top-decor-banner" aria-hidden="true">
          <div class="top-decor-banner__cap"></div>
          <div class="top-decor-banner__body"></div>
        </div>

        <div class="hero-layer-over">
          <div class="art-carousel-track">
            {
              heroSlides.map((slide: any, i: number) => (
                <div class={`art-carousel-slide ${i === 0 ? "is-active" : ""}`}>
                  <a
                    href={slide.link}
                    target={slide.target}
                    class="slide-link"
                    draggable="false"
                  >
                    <img
                      src={slide.url}
                      alt={`Kimeyu Hero Artwork ${i + 1}`}
                      class="slide-img"
                      decoding="async"
                      draggable="false"
                    />
                  </a>
                </div>
              ))
            }
            {/* Ảo ảnh (Clone) để tạo Infinite Loop nối đuôi */}
            {
              heroSlides.length > 0 && (
                <div class="art-carousel-slide slick-cloned" aria-hidden="true">
                  <a
                    href={heroSlides[0].link}
                    target={heroSlides[0].target}
                    class="slide-link"
                    draggable="false"
                    tabindex="-1"
                  >
                    <img
                      src={heroSlides[0].url}
                      alt="Kimeyu Hero Artwork Clone"
                      class="slide-img"
                      decoding="async"
                      draggable="false"
                    />
                  </a>
                </div>
              )
            }
          </div>
        </div>

        <div class="bottom-decor-banner" aria-hidden="true">
          <div class="bottom-decor-banner__cap"></div>
          <div class="bottom-decor-banner__body"></div>
        </div>
      </section>

      <!-- MEDIA PLAYER WIDGET -->
      <div class="kime-media-player" aria-label="Decorative Media Controls">
        <div class="kime-media-track"></div>
        <div class="kime-media-controls">
          <button
            class="kime-media-btn kime-media-btn--prev"
            aria-label="Previous Track"></button>
          <button
            class="kime-media-btn kime-media-btn--pause"
            aria-label="Pause"></button>
          <button
            class="kime-media-btn kime-media-btn--next"
            aria-label="Next Track"></button>
        </div>
      </div>

      <!-- INVERTED BANNER STRIP -->
      <div class="contact-bottom-ribbon">
        <nav class="ribbon-nav-dots" aria-label="Page Navigation">
          {
            heroSlides.map((_, i) => (
              <button
                class={`nav-dot ${i === 0 ? "nav-dot--active" : ""}`}
