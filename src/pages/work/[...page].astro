---
import Layout from "../../layouts/Layout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import ModeSwitch from "../../components/ModeSwitch.astro";
import FilterMenu from "../../components/FilterMenu.astro";
import Pagination from "../../components/Pagination.astro";
import type { GetStaticPaths, Page } from "astro";

interface Artwork {
	thumbSrc: string;
	fullSrc: string;
	alt: string;
}

interface Props {
	page: Page<Artwork>;
}

// SSG ENGINE: Chia trang lúc Build-time
export const getStaticPaths = (({ paginate }) => {
	const artworksBase = [
		{ src: "https://picsum.photos/seed/k1/400/600", alt: "Artwork 1" },
		{ src: "https://picsum.photos/seed/k2/500/400", alt: "Artwork 2" },
		{ src: "https://picsum.photos/seed/k3/400/450", alt: "Artwork 3" },
		{ src: "https://picsum.photos/seed/k4/400/700", alt: "Artwork 4" },
		{ src: "https://picsum.photos/seed/k5/600/400", alt: "Artwork 5" },
		{ src: "https://picsum.photos/seed/k6/400/500", alt: "Artwork 6" },
		{ src: "https://picsum.photos/seed/k7/450/750", alt: "Artwork 7" },
		{ src: "https://picsum.photos/seed/k8/500/350", alt: "Artwork 8" },
		{ src: "https://picsum.photos/seed/k9/400/550", alt: "Artwork 9" },
		{ src: "https://picsum.photos/seed/k10/450/450", alt: "Artwork 10" },
		{ src: "https://picsum.photos/seed/k11/500/650", alt: "Artwork 11" },
		{ src: "https://picsum.photos/seed/k12/600/400", alt: "Artwork 12" },
		{ src: "https://picsum.photos/seed/k13/400/500", alt: "Artwork 13" },
		{ src: "https://picsum.photos/seed/k14/450/600", alt: "Artwork 14" },
		{ src: "https://picsum.photos/seed/k15/500/400", alt: "Artwork 15" },
		{ src: "https://picsum.photos/seed/k16/400/700", alt: "Artwork 16" },
		{ src: "https://picsum.photos/seed/k17/550/400", alt: "Artwork 17" },
		{ src: "https://picsum.photos/seed/k18/450/500", alt: "Artwork 18" },
		{ src: "https://picsum.photos/seed/k19/400/650", alt: "Artwork 19" },
		{ src: "https://picsum.photos/seed/k20/500/450", alt: "Artwork 20" },
		{ src: "https://picsum.photos/seed/k21/450/550", alt: "Artwork 21" },
		{ src: "https://picsum.photos/seed/k22/600/400", alt: "Artwork 22" },
		{ src: "https://picsum.photos/seed/k23/400/500", alt: "Artwork 23" },
		{ src: "https://picsum.photos/seed/k24/500/700", alt: "Artwork 24" },
		{ src: "https://picsum.photos/seed/k25/400/650", alt: "Artwork 25" },
		{ src: "https://picsum.photos/seed/k26/500/450", alt: "Artwork 26" },
		{ src: "https://picsum.photos/seed/k27/450/550", alt: "Artwork 27" },
		{ src: "https://picsum.photos/seed/k28/600/400", alt: "Artwork 28" },
		{ src: "https://picsum.photos/seed/k29/400/500", alt: "Artwork 29" },
		{ src: "https://picsum.photos/seed/k30/500/700", alt: "Artwork 30" },
		{ src: "https://picsum.photos/seed/k1/400/600", alt: "Artwork 1" },
		{ src: "https://picsum.photos/seed/k2/500/400", alt: "Artwork 2" },
		{ src: "https://picsum.photos/seed/k3/400/450", alt: "Artwork 3" },
		{ src: "https://picsum.photos/seed/k4/400/700", alt: "Artwork 4" },
		{ src: "https://picsum.photos/seed/k5/600/400", alt: "Artwork 5" },
		{ src: "https://picsum.photos/seed/k6/400/500", alt: "Artwork 6" },
		{ src: "https://picsum.photos/seed/k7/450/750", alt: "Artwork 7" },
		{ src: "https://picsum.photos/seed/k8/500/350", alt: "Artwork 8" },
		{ src: "https://picsum.photos/seed/k9/400/550", alt: "Artwork 9" },
		{ src: "https://picsum.photos/seed/k10/450/450", alt: "Artwork 10" },
		{ src: "https://picsum.photos/seed/k11/500/650", alt: "Artwork 11" },
		{ src: "https://picsum.photos/seed/k12/600/400", alt: "Artwork 12" },
		{ src: "https://picsum.photos/seed/k13/400/500", alt: "Artwork 13" },
		{ src: "https://picsum.photos/seed/k14/450/600", alt: "Artwork 14" },
		{ src: "https://picsum.photos/seed/k15/500/400", alt: "Artwork 15" },
		{ src: "https://picsum.photos/seed/k16/400/700", alt: "Artwork 16" },
		{ src: "https://picsum.photos/seed/k17/550/400", alt: "Artwork 17" },
		{ src: "https://picsum.photos/seed/k18/450/500", alt: "Artwork 18" },
		{ src: "https://picsum.photos/seed/k19/400/650", alt: "Artwork 19" },
		{ src: "https://picsum.photos/seed/k20/500/450", alt: "Artwork 20" },
		{ src: "https://picsum.photos/seed/k21/450/550", alt: "Artwork 21" },
		{ src: "https://picsum.photos/seed/k22/600/400", alt: "Artwork 22" },
		{ src: "https://picsum.photos/seed/k23/400/500", alt: "Artwork 23" },
		{ src: "https://picsum.photos/seed/k24/500/700", alt: "Artwork 24" },
		{ src: "https://picsum.photos/seed/k25/400/650", alt: "Artwork 25" },
		{ src: "https://picsum.photos/seed/k26/500/450", alt: "Artwork 26" },
		{ src: "https://picsum.photos/seed/k27/450/550", alt: "Artwork 27" },
		{ src: "https://picsum.photos/seed/k28/600/400", alt: "Artwork 28" },
		{ src: "https://picsum.photos/seed/k29/400/500", alt: "Artwork 29" },
		{ src: "https://picsum.photos/seed/k30/500/700", alt: "Artwork 30" },
	];

	const artworks: Artwork[] = artworksBase.map((art) => {
		// Parse kích thước gốc từ URL picsum: .../seed/kN/{w}/{h}
		const parts = art.src.split("/");
		const h = parseInt(parts[parts.length - 1]);
		const w = parseInt(parts[parts.length - 2]);
		// Scale lên x3 giữ nguyên tỷ lệ gốc
		return {
			thumbSrc: art.src,
			fullSrc: `https://picsum.photos/seed/${parts[parts.length - 3]}/${w * 3}/${h * 3}`,
			alt: art.alt,
		};
	});

	return paginate(artworks, { pageSize: 9 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<Layout title={`Kime Work - Page ${page.currentPage}`}>
	<script is:inline slot="head">
		(function () {
			function syncWorkMode() {
				var h = location.hash.replace("#", "");
				document.documentElement.dataset.workMode =
					h === "artwork" ? "artwork" : "motions";
			}
			syncWorkMode();
			document.addEventListener("astro:after-swap", syncWorkMode);
		})();
	</script>

	<Fragment slot="banner">
		<div class="works-hero-group">
			<SectionHeader
				title="WORKS"
				isBanner={true}
				isHeroBanner={true}
				align="responsive"
			/>
			<div class="switch-overlap">
				<ModeSwitch />
			</div>
		</div>
	</Fragment>

	<div class="works-content">
		<work-gallery-manager>
			<section data-mode="motions" class="gallery-view">
				<SectionHeader
					title="MOTIONS"
					subtitle="モーションプロジェクト"
					align="responsive"
				/>
				<div class="wrapper">
					<FilterMenu
						groupName="motions-filter"
						options={[
							{ label: "ALL MOTIONS", value: "all" },
							{ label: "3D ANIMATION", value: "3d" },
							{ label: "2D MOTION", value: "2d" },
						]}
					/>
				</div>
			</section>

			<section data-mode="artwork" class="gallery-view">
				<SectionHeader
					title="ARTWORK"
					subtitle="作品"
					align="responsive"
				/>
				<div class="wrapper">
					<FilterMenu
						groupName="artwork-filter"
						options={[
							{ label: "ILLUSTRATION", value: "illustration" },
							{ label: "GRAPHICS DESIGN", value: "graphics" },
						]}
					/>

					<div class="artwork-masonry" id="works-gallery">
						{
							page.data.map((art, index) => (
								<div
									class="artwork-card"
									role="button"
									tabindex="0"
									data-full-src={art.fullSrc}
								>
									<img
										src={art.thumbSrc}
										loading={index < 3 ? "eager" : "lazy"}
										fetchpriority={
											index < 3 ? "high" : "auto"
										}
										decoding={index < 3 ? "sync" : "async"}
										alt={art.alt}
									/>
								</div>
							))
						}
					</div>

					<div
						role="separator"
						aria-hidden="true"
						class="artwork-loader-decor"
					>
					</div>

					<Pagination
						page={page}
						baseUrl="/work"
						targetId="works-gallery"
					/>
				</div>
			</section>

			<dialog class="lightbox-modal">
				<header class="lightbox-header">
					<div class="lightbox-title-group">
						<h2 class="lightbox-title">PREVIEW</h2>
					</div>
					<button class="lightbox-close" aria-label="Close preview"
						>✕</button
					>
				</header>
				<div class="lightbox-body">
					<img src="" alt="" class="lightbox-img" decoding="async" />
				</div>
			</dialog>
		</work-gallery-manager>
	</div>
</Layout>

<script>
	class WorkGalleryManager extends HTMLElement {
		private _dialog: HTMLDialogElement | null = null;

		constructor() {
			super();
			this.handleCardClick = this.handleCardClick.bind(this);
			this.handleHashChange = this.handleHashChange.bind(this);
		}

		connectedCallback() {
			this._dialog =
				this.querySelector<HTMLDialogElement>(".lightbox-modal");
			this.initLightbox();

			// TRẢ LẠI: Lắng nghe hashchange để cái ModeSwitch hoạt động
			window.addEventListener("hashchange", this.handleHashChange);

			const gallery = this.querySelector(".artwork-masonry");
			if (gallery)
				gallery.addEventListener("click", this.handleCardClick);
		}

		disconnectedCallback() {
			window.removeEventListener("hashchange", this.handleHashChange);

			const gallery = this.querySelector(".artwork-masonry");
			if (gallery)
				gallery.removeEventListener("click", this.handleCardClick);
			this._dialog = null;
		}

		private handleHashChange() {
			const hash = window.location.hash.replace("#", "");
			if (hash === "artwork" || hash === "motions") {
				document.documentElement.dataset.workMode = hash;
			}
		}

		private initLightbox() {
			if (!this._dialog) return;

			const closeBtn = this._dialog.querySelector(".lightbox-close");
			closeBtn?.addEventListener("click", () => this._dialog?.close());

			this._dialog.addEventListener("click", (e) => {
				if (e.target === this._dialog) this._dialog?.close();
			});
		}

		private handleCardClick(e: Event) {
			const card = (e.target as HTMLElement).closest<HTMLElement>(
				".artwork-card",
			);
			if (!card || !this._dialog) return;

			const fullSrc = card.dataset.fullSrc;
			const img = card.querySelector("img");

			if (!fullSrc || !img) return;

			const dialogImg =
				this._dialog.querySelector<HTMLImageElement>(".lightbox-img");
			if (dialogImg) {
				dialogImg.src = fullSrc;
				dialogImg.alt = img.alt || "Expanded artwork preview";
				this._dialog.showModal();
			}
		}
	}

	if (!customElements.get("work-gallery-manager")) {
		customElements.define("work-gallery-manager", WorkGalleryManager);
	}
</script>

<style>
	.wrapper {
		max-width: var(--content-max-width);
		margin: 0 auto;
		padding: 0 clamp(var(--spacing-4), 5vw, var(--spacing-8));
	}

	.works-hero-group {
		position: relative;
		background-color: var(--accent-primary);
		padding-bottom: clamp(1rem, 3vw, var(--spacing-4));
	}

	.switch-overlap {
		position: relative;
		z-index: 10;
		margin-top: clamp(-2.5rem, -6vw, -4rem);
		padding: 0 clamp(var(--spacing-1), 1.5vw, var(--spacing-4));
	}

	.works-content {
		padding-top: var(--spacing-8);
	}

	.banner-headers {
		display: flex;
		flex-direction: column;
	}

	work-gallery-manager {
		display: block;
		width: 100%;
		min-height: 50vh;
	}

	:global(html[data-work-mode="motions"]) .gallery-view[data-mode="artwork"],
	:global(html[data-work-mode="artwork"]) .gallery-view[data-mode="motions"] {
		display: none !important;
	}

	.artwork-card[hidden] {
		display: none !important;
	}

	.artwork-masonry {
		column-count: 1;
		column-gap: var(--spacing-4);
		padding-top: var(--spacing-4);
	}

	.artwork-card {
		break-inside: avoid;
		position: relative;
		overflow: hidden;
		margin-bottom: var(--spacing-4);
		background-color: color-mix(
			in srgb,
			var(--color-primary) 50%,
			transparent
		);
		padding: clamp(6px, 1.5vw, 12px) clamp(6px, 1.5vw, 12px)
			clamp(16px, 3vw, 24px);
		transition:
			background-color 0.3s ease,
			transform 0.3s ease,
			box-shadow 0.3s ease;
		cursor: pointer;
	}

	.artwork-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
		background-color: rgba(255, 205, 221, 0.5);
	}

	.artwork-card img {
		width: 100%;
		height: auto;
		display: block;
		object-fit: cover;
		content-visibility: auto;
	}

	/* LIGHTBOX MODAL */
	.lightbox-modal {
		--win-border: var(--color-secondary-darker);
		--win-bg-header: var(--color-secondary-light);
		--win-bg-body: var(--bg-secondary);
		--win-text-dark: var(--color-secondary-darker);
		--win-accent-pink: var(--color-accent-badge);
		--win-radius: var(--spacing-3);

		padding: 0;
		margin: auto;
		background-color: var(--win-bg-body);
		border: var(--border-width-sm) solid var(--win-border);
		border-radius: var(--win-radius);

		width: fit-content;
		min-width: min(300px, 90vw);
		max-width: 95vw;
		max-height: 95vh;
		overflow: hidden;
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
	}

	.lightbox-modal[open] {
		display: flex;
		flex-direction: column;
	}

	.lightbox-modal::backdrop {
		background-color: rgba(0, 0, 0, 0.85);
		backdrop-filter: blur(5px);
		cursor: zoom-out;
	}

	.lightbox-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		background-color: var(--win-bg-header);
		border-bottom: var(--border-width-sm) solid var(--win-border);
		padding: var(--spacing-3) var(--spacing-6);
		flex-shrink: 0;
	}

	.lightbox-title-group {
		display: flex;
		align-items: center;
	}

	.lightbox-title {
		margin: 0;
		font-size: var(--text-base);
		font-weight: 900;
		color: var(--win-text-dark);
		letter-spacing: 0.05em;
		display: flex;
		align-items: center;
	}

	.lightbox-title::before {
		content: "";
		display: inline-block;
		width: var(--spacing-6);
		height: var(--spacing-6);
		background-color: var(--win-accent-pink);
		border: var(--border-width-sm) solid var(--win-border);
		border-radius: 50%;
		margin-right: var(--spacing-4);
		vertical-align: middle;
		flex-shrink: 0;
	}

	.lightbox-close {
		background: transparent;
		border: none;
		color: var(--win-text-dark);
		font-size: var(--text-2xl);
		font-weight: 900;
		line-height: 1;
		cursor: pointer;
		transition:
			color 0.2s ease,
			transform 0.2s ease;
		padding: 0 0 0 var(--spacing-4);
	}

	.lightbox-close:hover {
		color: var(--color-primary);
		transform: scale(1.1);
	}

	.lightbox-body {
		padding: var(--spacing-4);
		overflow-y: auto;
		display: flex;
		justify-content: center;
		align-items: center;
		background-image: radial-gradient(
			var(--color-tertiary) 1px,
			transparent 0
		);
		background-size: 20px 20px;
	}

	.lightbox-img {
		display: block;
		width: auto;
		height: auto;
		max-width: 100%;
		max-height: calc(95vh - 100px);
		border: var(--border-width-sm) solid var(--win-border);
		border-radius: var(--radius-sm);
	}

	:global(body:has(dialog[open])) {
		overflow: hidden;
	}

	/* ARTWORK LOADER DECOR */
	.artwork-loader-decor {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: space-between;

		width: 100%;
		border: none;
		--cell: clamp(10px, 1.2vw, 16px);
		height: calc(var(--cell) * 3);
		background-color: var(--color-primary);
		margin: clamp(var(--spacing-8), 6vw, var(--spacing-12)) 0 0 0;

		--gap: calc(var(--cell) * 2);
		background-image:
			radial-gradient(circle closest-side, #ffffff 98%, transparent 100%),
			radial-gradient(circle closest-side, #ffffff 98%, transparent 100%),
			radial-gradient(circle closest-side, #ffffff 98%, transparent 100%);
		background-size: var(--cell) var(--cell);
		background-repeat: no-repeat;
		background-position:
			calc(50% - var(--gap)) 50%,
			50% 50%,
			calc(50% + var(--gap)) 50%;
	}

	.artwork-loader-decor::before,
	.artwork-loader-decor::after {
		content: "";
		position: absolute;
		top: 0;
		width: calc(var(--cell) * 5);
		height: 100%;
		background-image: repeating-conic-gradient(
			#ffffff 0 90deg,
			transparent 0 180deg
		);
		background-size: calc(var(--cell) * 2) calc(var(--cell) * 2);
	}

	.artwork-loader-decor::before {
		left: 0;
	}
	.artwork-loader-decor::after {
		right: 0;
	}

	@media (min-width: 640px) {
		.artwork-masonry {
			column-count: 2;
			column-gap: var(--spacing-6);
		}
		.artwork-card {
			margin-bottom: var(--spacing-6);
		}
	}

	@media (min-width: 1024px) {
		.artwork-masonry {
			column-count: 3;
			column-gap: clamp(var(--spacing-6), 2vw, var(--spacing-8));
		}
		.artwork-card {
			margin-bottom: clamp(var(--spacing-6), 2vw, var(--spacing-8));
		}
	}
</style>
