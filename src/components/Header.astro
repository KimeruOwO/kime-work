---
import KimeLogo from "./icons/KimeLogo.astro";
import KimeyuIcon from "./icons/KimeyuIcon.astro";

const currentPath = Astro.url.pathname;

// JS Hiện đại: Strict Type và Logic gọn gàng
const getActiveAttr = (path: string): "page" | undefined => {
  if (currentPath === path || currentPath.startsWith(`${path}/`)) {
    return "page";
  }
  return undefined;
};
---

<header class="cyber-header">
  <a href="/" class="cyber-header__logo-link" aria-label="Home">
    <KimeLogo />
  </a>

  <div class="cyber-header__right">
    <!-- DOM RÁC ĐÃ BỊ TIÊU DIỆT. Gắn class trực tiếp vào Icon -->
    <KimeyuIcon class="cyber-header__brand-icon" />
  </div>

  <nav class="cyber-header__nav">
    <a
      href="/about"
      class="cyber-header__nav-btn"
      aria-current={getActiveAttr("/about")}
    >
      ABOUT
    </a>
    <a
      href="/work"
      class="cyber-header__nav-btn"
      aria-current={getActiveAttr("/work")}
    >
      WORKS
    </a>
    <a
      href="/contact"
      class="cyber-header__nav-btn"
      aria-current={getActiveAttr("/contact")}
    >
      CONTACT
    </a>
  </nav>
</header>

<style>
  .cyber-header {
    display: flex;
    flex-wrap: wrap;
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    background-color: var(--color-primary);
    font-family: var(--font-sans);
    box-shadow:
      0 var(--border-width-sm) 0 0 var(--bg-secondary),
      0 calc(var(--border-width-md) + 4px) 0 0 var(--color-secondary-light);
  }

  .cyber-header__logo-link {
    display: flex;
    flex: 1;
    align-items: center;
    align-self: center;
    padding: 0 var(--spacing-6);
    height: var(--spacing-12);
    color: var(--bg-secondary);
  }

  .cyber-header__logo-link :global(svg) {
    height: var(--spacing-6);
    width: auto;
  }

  .cyber-header__nav {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    order: 3;
    width: 100%;
    padding: var(--spacing-2) 0;
    gap: var(--spacing-2);
  }

  /* TOÁN HỌC ĐỘNG CHO CARO DƯỚI NAV (SCALE KHÔNG GIỚI HẠN) */
  .cyber-header__nav::before,
  .cyber-header__nav::after {
    content: "";
    --blocks-x: 2; /* Giảm số ô ngang xuống 2 để tiết kiệm 1 khoảng trống khổng lồ cho màn hình nhỏ */
    --blocks-y: 3; /* Cố định 2 ô chiều dọc để form cân đối với chiều cao Nav */

    /* Xếp chồng lên phần padding của Nav bằng Margin âm để chiếm trọn vẹn chiều cao */
    margin-top: calc(-1 * var(--spacing-2));
    margin-bottom: calc(-1 * var(--spacing-2));

    /* Giao phó hoàn toàn tỷ lệ cho aspect-ratio để width tự động nở ra dựa trên height */
    aspect-ratio: var(--blocks-x) / var(--blocks-y);

    background: repeating-conic-gradient(
        transparent 0 90deg,
        var(--bg-secondary) 0 180deg
      )
      0 0 / calc(100% / var(--blocks-x) * 2) calc(100% / var(--blocks-y) * 2);
  }

  .cyber-header__nav::before {
    margin-right: auto;
  }
  .cyber-header__nav::after {
    margin-left: auto;
  }

  .cyber-header__nav-btn {
    align-self: center;
    /* Tự động co bóp lề ngang trên các máy siêu nhỏ (như iPhone SE 375px), nở ra trên máy lớn */
    padding: var(--spacing-2) clamp(var(--spacing-2), 3vw, var(--spacing-4));
    background-color: var(--bg-secondary);
    color: var(--color-primary);
    font-size: var(--text-xs);
    font-weight: 900;
    letter-spacing: 0.15em;
    text-align: center;
    border-radius: var(--radius-pill);
    transition:
      transform 0.2s ease,
      filter 0.2s ease;
  }

  .cyber-header__nav-btn:hover {
    transform: translateY(-2px);
    filter: brightness(0.9);
  }

  .cyber-header__nav-btn[aria-current="page"] {
    background-color: var(--color-black-active);
    color: var(--text-inverse);
  }

  .cyber-header__right {
    display: flex;
    flex: none;
    align-items: center;
    background-color: var(--bg-secondary);
    min-height: var(--spacing-12);
  }

  /* TOÁN HỌC ĐỘNG CHO CARO BÊN PHẢI (KỸ SƯ HỆ THỐNG) */
  .cyber-header__right::before {
    content: "";
    --blocks-x: 6; /* Số ô caro theo chiều ngang (Bạn tùy ý tăng giảm ở đây nhé) */
    --blocks-y: 3; /* Số ô caro theo chiều dọc (Nên cố định 3 để khít viền) */

    /* 1) Chiều cao gắn cứng theo Header hiện tại */
    height: var(--spacing-12);
    /* Tỷ lệ khung hình tự nở ra dựa trên cấu hình lưới, không cần set width cứng */
    aspect-ratio: var(--blocks-x) / var(--blocks-y);

    /* 2) Background tự đo đạc không gian X/Y để vẽ chính xác không móp méo */
    background: repeating-conic-gradient(
        transparent 0 90deg,
        var(--checkerboard-primary) 0 180deg
      )
      0 0 / calc(100% / var(--blocks-x) * 2) calc(100% / var(--blocks-y) * 2);
  }

  /* Ghi đè trực tiếp lên SVG, cần dùng :global để xuyên qua component Astro */
  .cyber-header__right :global(.cyber-header__brand-icon) {
    height: var(--spacing-4);
    width: auto;
    color: var(--color-primary);
    padding: 0 var(--spacing-6);
  }

  /* ==========================================================
     RESPONSIVE TABLET (>= 768px)
  ========================================================== */
  @media (min-width: 768px) {
    .cyber-header {
      flex-wrap: nowrap;
      height: var(--header-height-pc);
    }

    .cyber-header__logo-link {
      flex: none;
      padding: 0 0 0 clamp(var(--spacing-6), 4vw, var(--spacing-12));
      height: var(--spacing-12);
    }

    .cyber-header__nav {
      order: 2;
      width: auto;
      padding: 0 clamp(var(--spacing-8), 5vw, var(--spacing-20));
      gap: clamp(var(--spacing-2), 2vw, var(--spacing-8));
    }

    .cyber-header__nav::before,
    .cyber-header__nav::after {
      display: none;
    }

    .cyber-header__right {
      order: 3;
      margin-left: auto;
      padding-right: var(--spacing-4);
      flex: none;
    }

    .cyber-header__right::before {
      --blocks-x: 5;
      --blocks-y: 3;
      height: var(--header-height-pc);
    }

    .cyber-header__right :global(.cyber-header__brand-icon) {
      height: var(--spacing-6);
      padding: 0 var(--spacing-8);
    }

    .cyber-header__nav-btn {
      font-size: var(--text-sm);
      padding: var(--spacing-2) clamp(var(--spacing-2), 1vw, var(--spacing-4));
    }
  }

  /* ==========================================================
     RESPONSIVE LAGE PC (>= 1024px)
  ========================================================== */
  @media (min-width: 1024px) {
    .cyber-header__logo-link {
      padding: 0 0 0 clamp(var(--spacing-8), 6vw, var(--spacing-20));
    }

    .cyber-header__logo-link :global(svg) {
      height: var(--spacing-10);
    }

    .cyber-header__nav {
      padding: 0 clamp(var(--spacing-8), 6vw, var(--spacing-20));
    }

    .cyber-header__right {
      gap: clamp(var(--spacing-6), 4vw, var(--spacing-12));
      padding-right: clamp(var(--spacing-8), 5vw, var(--spacing-16));
    }

    .cyber-header__right::before {
      --checker-cell: 60px;
      --blocks: 3; /* Cố định 3 ô như yêu cầu */
    }

    .cyber-header__nav-btn {
      font-size: var(--text-lg);
      padding: var(--spacing-2) clamp(var(--spacing-4), 2vw, var(--spacing-12));
    }
  }
</style>
