---
import KimeLogo from "./icons/KimeLogo.astro";
import KimeyuIcon from "./icons/KimeyuIcon.astro";

const rawPath = Astro.url.pathname;
const currentPath =
  rawPath.length > 1 && rawPath.endsWith("/") ? rawPath.slice(0, -1) : rawPath;

const isAbout = currentPath === "/about";
const isHome = currentPath === "/home";

// Nhận diện active state cực mượt bằng độ phức tạp O(1)
const isWorks = currentPath.startsWith("/work");
---

<header class="cyber-header">
  <a
    href="/home"
    class="cyber-header__logo-link"
    aria-label="Home"
    data-astro-prefetch="hover"
  >
    <KimeLogo />
  </a>

  <div class="cyber-header__right">
    <KimeyuIcon class="cyber-header__brand-icon" />
  </div>

  <nav class="cyber-header__nav">
    <a
      href="/about"
      class="cyber-header__nav-btn"
      aria-current={isAbout ? "page" : undefined}
      data-astro-prefetch="hover"
    >
      ABOUT
    </a>

    <a
      href="/work/motions"
      class="cyber-header__nav-btn"
      aria-current={isWorks ? "page" : undefined}
      data-astro-prefetch="hover"
      data-works-link
    >
      WORKS
    </a>

    <a
      href="/home"
      class="cyber-header__nav-btn"
      aria-current={isHome ? "page" : undefined}
      data-astro-prefetch="hover"
    >
      HOME
    </a>
  </nav>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const path = window.location.pathname.replace(/\/$/, "");
    const link = document.querySelector<HTMLAnchorElement>("[data-works-link]");
    if (!link) return;

    // Save mode when user is on a works page
    if (path.startsWith("/work/motions")) {
      localStorage.setItem("kime-works-mode", "motions");
    } else if (path.startsWith("/work/artwork")) {
      localStorage.setItem("kime-works-mode", "artwork");
    }

    // Update WORKS link to match saved preference (default: motions)
    const savedMode = localStorage.getItem("kime-works-mode");
    link.href = savedMode === "artwork" ? "/work/artwork/" : "/work/motions";
  });
</script>

<style>
  .cyber-header {
    display: flex;
    flex-wrap: wrap;
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    background-color: var(--color-primary);
    font-family: var(--font-sans);
    box-shadow:
      0 var(--border-width-sm) 0 0 var(--bg-secondary),
      0 calc(var(--border-width-md) + 4px) 0 0 var(--color-secondary-light);
  }

  .cyber-header__logo-link {
    display: flex;
    flex: 1;
    align-items: center;
    align-self: center;
    padding: 0 var(--spacing-6);
    height: var(--spacing-12);
    color: var(--bg-secondary);
  }

  .cyber-header__logo-link :global(svg) {
    height: var(--spacing-6);
    width: auto;
  }

  .cyber-header__nav {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    order: 3;
    width: 100%;
    padding: var(--spacing-2) 0;
    gap: var(--spacing-2);
  }

  /* TOÁN HỌC ĐỘNG CHO CARO DƯỚI NAV (SCALE KHÔNG GIỚI HẠN) */
  .cyber-header__nav::before,
  .cyber-header__nav::after {
    content: "";
    --blocks-x: 3; /* Giảm số ô ngang xuống 2 để tiết kiệm 1 khoảng trống khổng lồ cho màn hình nhỏ */
    --blocks-y: 3; /* Cố định 2 ô chiều dọc để form cân đối với chiều cao Nav */

    /* Xếp chồng lên phần padding của Nav bằng Margin âm để chiếm trọn vẹn chiều cao */
    margin-top: calc(-1 * var(--spacing-2));
    margin-bottom: calc(-1 * var(--spacing-2));

    /* Giao phó hoàn toàn tỷ lệ cho aspect-ratio để width tự động nở ra dựa trên height */
    aspect-ratio: var(--blocks-x) / var(--blocks-y);

    background-color: var(
      --color-primary
    ); /* Đảm bảo nền cơ sở là màu chính để che khe nứt vi điểm */
    background-image: repeating-conic-gradient(
      var(--color-primary) 0 90deg,
      var(--bg-secondary) 0 180deg
    );
    /* Tăng Scale nhẹ 0.5px để bù trừ sai số dấu phẩy động của Firefox (Subpixel Anti-aliasing) */
    background-size: calc((100% + 0.5px) / var(--blocks-x) * 2)
      calc((100% + 0.5px) / var(--blocks-y) * 2);
    /* Set explicitly to avoid subpixel overlap errors */
    background-position: 0 0;
  }

  .cyber-header__nav::before {
    margin-right: auto;
  }
  .cyber-header__nav::after {
    margin-left: auto;
  }

  .cyber-header__nav-btn {
    align-self: center;
    /* Tự động co bóp lề ngang trên các máy siêu nhỏ (như iPhone SE 375px), nở ra trên máy lớn */
    padding: var(--spacing-2) clamp(var(--spacing-2), 3vw, var(--spacing-4));
    background-color: var(--bg-secondary);
    color: var(--color-primary);
    font-size: var(--text-xs);
    font-weight: 899;
    letter-spacing: 0.15em;
    text-align: center;
    border-radius: var(--radius-pill);
    transition:
      transform 0.2s ease,
      filter 0.2s ease;
  }

  .cyber-header__nav-btn:hover {
    transform: translateY(-2px);
    filter: brightness(0.9);
  }

  .cyber-header__nav-btn[aria-current="page"] {
    background-color: var(--color-black-active);
    color: var(--text-inverse);
  }

  .cyber-header__right {
    display: flex;
    flex: none;
    align-items: center;
    background-color: var(--bg-secondary);
    min-height: var(--spacing-12);
  }

  /* TOÁN HỌC ĐỘNG CHO CARO BÊN PHẢI (KỸ SƯ HỆ THỐNG) */
  .cyber-header__right::before {
    content: "";
    --blocks-x: 6; /* Số ô caro theo chiều ngang */
    --blocks-y: 3; /* Số ô caro theo chiều dọc */

    /* Trả lại kiến trúc Aspect-Ratio gốc (Chrome Flexbox Friendly) */
    height: var(--spacing-12);
    aspect-ratio: var(--blocks-x) / var(--blocks-y);
    flex-shrink: 0; /* Khoá tử không cho Flexbox bóp nghẹt khung hình (Nguyên nhân lỗi Chrome) */

    background-color: var(--color-primary); /* Đổi màu lót thành Pink để Firefox có rò rỉ pixel cũng không lộ */
    background-image: repeating-conic-gradient(
      var(--bg-secondary) 0 90deg,
      var(--color-primary) 0 180deg
    );
    /* Tăng Scale nhẹ 0.5px để triệt tiêu lỗi hở khe trắng do Firefox (Subpixel Tiling Bug) */
    background-size: calc((100% + 0.5px) / var(--blocks-x) * 2)
      calc((100% + 0.5px) / var(--blocks-y) * 2);
    background-position: 0 0;
  }

  /* Ghi đè trực tiếp lên SVG, cần dùng :global để xuyên qua component Astro */
  .cyber-header__right :global(.cyber-header__brand-icon) {
    height: var(--spacing-4);
    width: auto;
    color: var(--color-primary);
    padding: 0 var(--spacing-6);
  }

  /* ==========================================================
     RESPONSIVE KHI VƯỢT QUA MOBILE NHỎ (>= 480px)
  ========================================================== */
  @media (min-width: 480px) {
    .cyber-header__nav::before,
    .cyber-header__nav::after {
      --blocks-x: 5;
    }
  }

  /* ==========================================================
     RESPONSIVE TABLET (>= 768px)
  ========================================================== */
  @media (min-width: 768px) {
    .cyber-header {
      flex-wrap: nowrap;
      height: var(--header-height-pc);
    }

    .cyber-header__logo-link {
      flex: none;
      padding: 0 0 0 clamp(var(--spacing-6), 4vw, var(--spacing-12));
      height: var(--spacing-12);
    }

    .cyber-header__nav {
      order: 2;
      flex: 1; /* Hấp thụ linh hoạt khối không gian thừa */
      justify-content: flex-start; /* Thỏa đam mê bám trái theo ý chủ nhân */
      padding: 0 var(--spacing-4) 0
        clamp(var(--spacing-4), 3vw, var(--spacing-12)); /* Trả lại khoảng cách thẩm mỹ với Logo */
      gap: clamp(var(--spacing-2), 2vw, var(--spacing-8));
    }

    .cyber-header__nav::before,
    .cyber-header__nav::after {
      display: none;
    }

    .cyber-header__right {
      order: 3;
      margin-left: auto;
      padding-right: var(--spacing-4);
      flex: none;
    }

    .cyber-header__right::before {
      --blocks-x: 5;
      --blocks-y: 3;
      height: var(--header-height-pc);
    }

    .cyber-header__right :global(.cyber-header__brand-icon) {
      height: var(--spacing-6);
      padding: 0 var(--spacing-8);
    }

    .cyber-header__nav-btn {
      font-size: var(--text-sm);
      padding: var(--spacing-2) clamp(var(--spacing-2), 1vw, var(--spacing-4));
    }
  }

  /* ==========================================================
     RESPONSIVE LAGE PC (>= 1024px)
  ========================================================== */
  @media (min-width: 1024px) {
    .cyber-header__logo-link {
      padding: 0 0 0 clamp(var(--spacing-4), 4vw, var(--spacing-12));
    }

    .cyber-header__logo-link :global(svg) {
      height: var(--spacing-10);
    }

    /* cyber-header__nav tự động mượt mà thừa kế padding và flex-start từ 768px */

    .cyber-header__right {
      gap: clamp(var(--spacing-2), 2vw, var(--spacing-8));
      padding-right: clamp(var(--spacing-4), 4vw, var(--spacing-12));
    }



    .cyber-header__nav-btn {
      font-size: clamp(var(--text-base), 1.5vw, var(--text-lg));
      padding: var(--spacing-2) clamp(var(--spacing-3), 1.5vw, var(--spacing-8));
    }
  }
</style>
