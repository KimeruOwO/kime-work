---
// src/components/FilterMenu.astro
import FilterIcon from "./icons/FilterIcon.astro";
export interface FilterOption {
    label: string;
    value: string;
}

export interface Props {
    title?: string;
    groupName: string;
    options: FilterOption[];
    activeValue?: string;
}

const {
    title = "FILTER",
    groupName,
    options,
    activeValue = options[0]?.value,
} = Astro.props;
---

<filter-menu-ctrl class="filter-group" data-group={groupName}>
    <div class="filter-group__label">
        <span>{title}</span>
        <FilterIcon
            width="20"
            height="20"
            class="filter-icon"
            aria-hidden="true"
        />
    </div>

    <div class="filter-group__options">
        {
            options.map((opt) => (
                <button
                    class:list={[
                        "filter-btn",
                        opt.value === activeValue && "is-active",
                    ]}
                    data-value={opt.value}
                    aria-pressed={opt.value === activeValue ? "true" : "false"}
                >
                    {opt.label}
                </button>
            ))
        }
    </div>
</filter-menu-ctrl>

<script>
    class FilterMenuCtrl extends HTMLElement {
        connectedCallback() {
            const buttons = Array.from(this.querySelectorAll(".filter-btn"));
            const groupName = this.getAttribute("data-group");

            buttons.forEach((btn) => {
                btn.addEventListener("click", () => {
                    const targetValue = btn.getAttribute("data-value");
                    if (!targetValue || btn.classList.contains("is-active"))
                        return;

                    // Giải nén các nút và bỏ class active
                    buttons.forEach((b) => {
                        b.classList.remove("is-active");
                        b.setAttribute("aria-pressed", "false");
                    });

                    // Set Active cho nút vừa bấm
                    btn.classList.add("is-active");
                    btn.setAttribute("aria-pressed", "true");

                    // Bắn event ra DOM thông báo bộ lọc đã thay đổi
                    this.dispatchEvent(
                        new CustomEvent("filter-changed", {
                            detail: {
                                group: groupName,
                                value: targetValue,
                            },
                            bubbles: true,
                        }),
                    );
                });
            });
        }
    }

    if (!customElements.get("filter-menu-ctrl")) {
        customElements.define("filter-menu-ctrl", FilterMenuCtrl);
    }
</script>

<style>
    .filter-group {
        display: flex;
        align-items: stretch;
        width: 100%;
        gap: clamp(var(--spacing-2), 2vw, var(--spacing-4));
        margin-bottom: var(--spacing-8);
        user-select: none;
    }

    /* Mỏm bo 2 bên Trái, Phải - Tái sử dụng chung 1 Token Css */
    .filter-group__label,
    .filter-group::after {
        flex-shrink: 0;
        width: clamp(90px, 18vw, 150px);
        background-color: var(--color-primary); /* Nền hồng */
        border: var(--border-width-xs) solid var(--color-secondary-darker);
        box-shadow: 4px 4px 0 var(--color-secondary-bright); /* Bóng Xanh Cyan */
    }

    /* Label góc màn bên Trái */
    .filter-group__label {
        border-radius: var(--radius-4xl) 0 0 var(--radius-4xl);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-inverse);
        font-weight: 900;
        font-size: clamp(var(--text-sm), 3vw, var(--text-base));
        letter-spacing: 0.05em;
        padding: 0 var(--spacing-4);
    }

    /* Khối Bo góc phải trống rỗng (CẮT GỌT DOM - DÙNG GIẢ MẢO ::AFTER) */
    .filter-group::after {
        content: "";
        display: block;
        border-radius: 0 var(--radius-4xl) var(--radius-4xl) 0;
    }

    /* Danh sách Option 1 Tầng ở Giữa */
    .filter-group__options {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        gap: clamp(var(--spacing-2), 1.5vw, var(--spacing-4));
        justify-content: center;
    }

    /* Nút con */
    .filter-btn {
        flex: 1; /* Stretch cho bằng nhau */
        min-height: clamp(38px, 6vw, 48px);
        background-color: var(--color-secondary-light); /* Màu xanh Cyan lợt */
        border: var(--border-width-xs) solid var(--color-secondary-darker);
        border-radius: 0; /* Vuông chằn chặn */
        color: var(--color-secondary-darker);
        font-weight: 900;
        /* Giảm nhẹ hệ số chữ trên Tablet để tránh chiếm diện tích ngang */
        font-size: clamp(11px, 1.5vw, var(--text-base));
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        transition:
            background-color 0.2s ease,
            color 0.2s ease,
            box-shadow 0.2s ease,
            transform 0.2s ease,
            opacity 0.2s ease;

        display: flex;
        align-items: center;
        justify-content: center;
        /* Ép lề mềm để giải phóng không gian lúc bị chật */
        padding: 0 clamp(8px, 1.5vw, 16px);
        /* KHOÁ CHỐNG XUỐNG DÒNG: Tuyệt đối dàn hàng ngang 1 dòng duy nhất */
        white-space: nowrap;

        /* Bóng đổ Hồng Pink */
        box-shadow: 4px 4px 0 var(--color-primary);
    }

    /* Hover Nút chưa Active */
    .filter-btn:hover:not(.is-active) {
        transform: translate(-1px, -1px);
        box-shadow: 5px 5px 0 var(--color-primary);
        opacity: 0.9;
    }

    /* Trạng thái BẬT Lọc - Invert Màu nền để báo hiệu nổi bật */
    .filter-btn.is-active {
        background-color: var(--color-secondary-darker);
        color: var(--text-inverse);
        /* Ép bóng xẹp xuống như hiệu ứng Nút Lún Thật */
        box-shadow: 2px 2px 0 var(--color-primary);
        transform: translate(2px, 2px);
    }

    .filter-icon {
        flex-shrink: 0;
    }

    /* Breakpoint Tablet/PC: Chuyển sang bố cục Cột Ngang (Row Layout) */
    @media (min-width: 768px) {
        .filter-group {
            /* Giữ full width để kéo giãn đều các phần tử */
            width: 100%;
            margin: 0 auto var(--spacing-12);
        }

        .filter-group__label {
            gap: var(
                --spacing-2
            ); /* Hỗ trợ khoảng cách giữa Chữ và Icon trên PC */
        }

        /* Chuyển Options từ chồng lên nhau (Stack) sang xếp hàng ngang (Side-by-side) */
        .filter-group__options {
            flex-direction: row;
            min-width: unset;
        }

        /* Tăng nhẹ vách 2 bên để ôm trọn vòm cung đẹp hơn trên màn lớn */
        .filter-group__label,
        .filter-group::after {
            width: clamp(120px, 15vw, 180px);
        }
    }
</style>
