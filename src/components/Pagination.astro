---
import type { Page } from "astro";

export interface Props {
    page: Page<any>;
    baseUrl?: string;
    suffix?: string;
    targetId?: string;
}

const { page, baseUrl = "/work", suffix = "", targetId = "works-gallery" } = Astro.props;

const MAX_VISIBLE = 5;
let windowStart = Math.max(1, page.currentPage - Math.floor(MAX_VISIBLE / 2));
let windowEnd = windowStart + MAX_VISIBLE - 1;

if (windowEnd > page.lastPage) {
    windowEnd = page.lastPage;
    windowStart = Math.max(1, windowEnd - MAX_VISIBLE + 1);
}

const pages = Array.from(
    { length: windowEnd - windowStart + 1 },
    (_, i) => windowStart + i,
);

const getPageUrl = (p: number) => {
    const base = p === 1 ? baseUrl : `${baseUrl}/${p}`;
    return suffix ? `${base}/${suffix}` : base;
};

const prevPageNum = page.currentPage > 1 ? page.currentPage - 1 : page.lastPage;
const nextPageNum = page.currentPage < page.lastPage ? page.currentPage + 1 : 1;

const prevUrl = getPageUrl(prevPageNum);
const nextUrl = getPageUrl(nextPageNum);
---

<nav
    class="kime-pagination"
    role="navigation"
    aria-label="Pagination"
    data-target-id={targetId}
>
    <a
        href={prevUrl}
        class="page-nav-btn prev-btn"
        aria-label="Go to previous page"
        data-astro-prefetch="hover"
    >
        PREVIOUS
    </a>

    <ul class="page-numbers">
        {
            pages.map((p) => {
                const isActive = p === page.currentPage;
                return (
                    <li>
                        <a
                            href={getPageUrl(p)}
                            class={`page-link ${isActive ? "is-active" : ""}`}
                            aria-current={isActive ? "page" : undefined}
                            aria-label={`Go to page ${p}`}
                            data-astro-prefetch="hover"
                        >
                            {p}
                        </a>
                    </li>
                );
            })
        }
    </ul>

    <a
        href={nextUrl}
        class="page-nav-btn next-btn"
        aria-label="Go to next page"
        data-astro-prefetch="hover"
    >
        NEXT
    </a>
</nav>

<style>
    .kime-pagination {
        --cell: 30px;
        --checker-w: calc(var(--cell) * 1.5);

        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        margin-top: clamp(var(--spacing-8), 6vw, var(--spacing-12));
        width: 100%;
    }

    .page-nav-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: calc(var(--cell) * 1.5);

        color: var(--text-inverse);
        font-weight: 899;
        font-size: clamp(var(--text-base), 2vw, var(--text-lg));
        line-height: 1;
        text-decoration: none;

        background-color: transparent;
        border: none;
        cursor: pointer;
        transition:
            opacity 0.2s ease,
            transform 0.2s ease;

        background-image:
            linear-gradient(var(--color-primary), var(--color-primary)),
            repeating-conic-gradient(
                var(--color-primary) 0 90deg,
                transparent 0 180deg
            );

        background-size:
            calc(100% - var(--checker-w) + 1px) 100%,
            var(--cell) var(--cell);

        background-repeat: no-repeat, repeat;
    }

    .page-nav-btn:hover:not(.is-disabled) {
        transform: translateY(-2px);
    }

    .page-nav-btn.is-disabled {
        opacity: 0.4;
        cursor: not-allowed;
        pointer-events: none;
    }

    .prev-btn {
        padding: 0
            calc(
                clamp(var(--spacing-3), 2vw, var(--spacing-36)) +
                    var(--checker-w)
            )
            0 clamp(var(--spacing-3), 2vw, var(--spacing-6));
        background-position:
            left top,
            right top;
        justify-self: start;
    }

    .next-btn {
        padding: 0 clamp(var(--spacing-3), 2vw, var(--spacing-6)) 0
            calc(
                clamp(var(--spacing-3), 2vw, var(--spacing-36)) +
                    var(--checker-w)
            );
        background-position:
            right top,
            left top;
        justify-self: end;

        background-image:
            linear-gradient(var(--color-primary), var(--color-primary)),
            repeating-conic-gradient(
                transparent 0 90deg,
                var(--color-primary) 0 180deg
            );
    }

    .page-numbers {
        display: flex;
        gap: clamp(var(--spacing-2), 2vw, var(--spacing-4));
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .page-link {
        display: flex;
        align-items: center;
        justify-content: center;
        width: clamp(36px, 8vw, 50px);
        height: clamp(36px, 8vw, 50px);
        border: var(--border-width-sm) solid var(--color-primary);
        border-radius: 50%;
        color: var(--color-primary);
        font-weight: 899;
        font-size: var(--text-base);
        text-decoration: none;
        background-color: transparent;
        transition:
            background-color 0.2s ease,
            color 0.2s ease,
            border-color 0.2s ease;
    }

    .page-link:hover {
        background-color: var(--color-primary-light);
        color: var(--text-inverse);
        border-color: var(--color-primary-light);
    }

    .page-link.is-active {
        background-color: var(--color-primary);
        color: var(--text-inverse);
    }

    @media (max-width: 767px) {
        .kime-pagination {
            display: flex;
            --cell: 24px;
            flex-wrap: wrap;
            row-gap: clamp(var(--spacing-6), 6vw, var(--spacing-8));
            justify-content: space-between;
        }

        .page-numbers {
            order: -1;
            width: 100%;
            justify-content: center;
        }

        .page-nav-btn {
            font-size: var(--text-sm);
        }

        .page-link {
            width: 32px;
            height: 32px;
            font-size: var(--text-sm);
            border-width: 1px;
        }
    }
</style>
