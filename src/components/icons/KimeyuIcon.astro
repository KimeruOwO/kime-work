---
// src/components/icons/KimeyuIcon.astro
export interface Props {
  class?: string;
  width?: string | number;
  height?: string | number;
}

const { 
  class: className = "",
  width = "100%",
  height = "100%"
} = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 2302.5 471.06"
  width={width}
  height={height}
  class={`vector-icon ${className}`}
  aria-hidden="true"
  fill="currentColor"
>
  <use href="#kimeyu-logo" />
</svg>
