---
import FacebookIcon from "./icons/FacebookIcon.astro";
import XIcon from "./icons/XIcon.astro";
import YouTubeIcon from "./icons/YouTubeIcon.astro";
import PixivIcon from "./icons/PixivIcon.astro";
import { SOCIAL_LINKS } from "../lib/socials";

const iconMap: Record<string, any> = {
  facebook: FacebookIcon,
  x: XIcon,
  youtube: YouTubeIcon,
  pixiv: PixivIcon,
};
---

<footer class="site-footer">
  <div class="footer-socials">
    {
      SOCIAL_LINKS.map((link) => {
        const Icon = iconMap[link.platform];
        return (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={link.label}
            class="social-link"
          >
            <Icon />
          </a>
        );
      })
    }
  </div>

  <div class="footer-banner">
    <p class="footer-copyright">©KIMEYU ALL RIGHT RESERVED</p>
  </div>
</footer>

<style>
  .site-footer {
    --banner-h: clamp(42px, 8vw, 48px);
    --checker-cell: calc(var(--banner-h) / 1.5);
    --checker-cols: 1.5;

    display: flex;
    flex-direction: column;
    width: 100%;
    background-color: var(--bg-primary);
    margin-top: var(--spacing-12);
  }

  .footer-socials {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--spacing-8);
    padding: var(--spacing-8) 0;
  }

  .social-link {
    color: var(--base-black-800);
    width: clamp(1.5rem, 4vw, 2rem);
    height: clamp(1.5rem, 4vw, 2rem);
    display: block;
    transition: opacity 0.2s ease;
  }

  .social-link:hover {
    opacity: 0.7;
  }

  .social-link :global(svg) {
    width: 100%;
    height: 100%;
    fill: currentColor;
    display: block;
  }

  .footer-banner {
    height: var(--banner-h);
    background-color: var(--color-secondary-light);
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    overflow: hidden;
  }

  .footer-banner::before,
  .footer-banner::after {
    content: "";
    width: calc(var(--checker-cell) * var(--checker-cols));
    background-color: var(--color-secondary-light);
    background-image: repeating-conic-gradient(
      var(--bg-primary) 0 90deg,
      transparent 0 180deg
    );
    background-size: var(--checker-cell) calc(100% / 1.5);
    flex-shrink: 0;
  }

  .footer-banner::after {
    background-position: top right;
  }

  .footer-copyright {
    flex-grow: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0 var(--spacing-2);
    color: var(--color-secondary-darker);
    font-size: clamp(0.65rem, 3vw, var(--text-sm));
    font-weight: 899;
    letter-spacing: 0.05em;
    text-align: center;
    white-space: nowrap;
  }

  /* ==========================================================
       BẢN LỀ RESPONSIVE CHO PC
    ========================================================== */
  @media (min-width: 1024px) {
    .site-footer {
      --banner-h: 60px;
      --checker-cols: 3;
      flex-direction: row;
      align-items: stretch;
      padding-top: var(--spacing-2);
    }

    .footer-socials {
      flex: 0 0 45vw;
      padding: 0;
      background-color: var(--bg-primary);
      justify-content: start;
      padding-left: var(--spacing-16);
      gap: var(--spacing-8);
    }

    .footer-banner {
      flex: 1;
    }

    .footer-banner::after {
      display: none;
    }

    .footer-copyright {
      justify-content: flex-end;
      padding-right: var(--spacing-16);
      font-size: var(--text-base);
    }
  }
</style>
