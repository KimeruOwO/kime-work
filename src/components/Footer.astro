---
import FacebookIcon from "./icons/FacebookIcon.astro";
import XIcon from "./icons/XIcon.astro";
import YouTubeIcon from "./icons/YouTubeIcon.astro";
import PixivIcon from "./icons/PixivIcon.astro";
---

<footer class="site-footer">
    <div class="footer-socials">
        <a href="#" aria-label="Facebook" class="social-link"
            ><FacebookIcon /></a
        >
        <a href="#" aria-label="X (Twitter)" class="social-link"><XIcon /></a>
        <a href="#" aria-label="YouTube" class="social-link"><YouTubeIcon /></a>
        <a href="#" aria-label="Pixiv" class="social-link"><PixivIcon /></a>
    </div>

    <div class="footer-banner">
        <p class="footer-copyright">©KIMEYU ALL RIGHT RESERVED</p>
    </div>
</footer>

<style>
    /* BỐ CỤC CHÍNH ĐƯỢC ĐẨY LÊN THẺ CHA ĐỂ QUẢN LÝ BIẾN TOÀN CỤC */
    .site-footer {
        --banner-h: clamp(42px, 8vw, 48px);
        --checker-cell: calc(var(--banner-h) / 1.5);
        --checker-cols: 1.5; /* Số cột caro mặc định trên Mobile */

        display: flex;
        flex-direction: column; /* Mobile: Xếp dọc */
        width: 100%;
        background-color: var(--bg-primary);
        margin-top: var(--spacing-12);
    }

    /* Mặc định trên Mobile: Icons có padding để cách điệu */
    .footer-socials {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: var(--spacing-8);
        padding: var(--spacing-8) 0;
    }

    .social-link {
        color: var(--base-black-800);
        width: clamp(1.5rem, 4vw, 2rem);
        height: clamp(1.5rem, 4vw, 2rem);
        display: block;
        transition: opacity 0.2s ease;
    }

    .social-link:hover {
        opacity: 0.7;
    }

    .social-link :global(svg) {
        width: 100%;
        height: 100%;
        fill: currentColor;
        display: block;
    }

    .footer-banner {
        height: var(--banner-h);
        background-color: var(--color-secondary-light);
        display: flex;
        align-items: stretch;
        justify-content: space-between;
        overflow: hidden;
    }

    /* VẼ CARO CHUẨN TOÁN HỌC - KHÔNG DOM RÁC */
    .footer-banner::before,
    .footer-banner::after {
        content: "";
        width: calc(var(--checker-cell) * var(--checker-cols));
        background-color: var(--color-secondary-light);
        background-image: repeating-conic-gradient(
            var(--bg-primary) 0 90deg,
            transparent 0 180deg
        );
        background-size: var(--checker-cell) var(--checker-cell);
        flex-shrink: 0;
    }

    .footer-banner::after {
        background-position: top right;
    }

    .footer-copyright {
        flex-grow: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
        padding: 0 var(--spacing-2);
        color: var(--color-secondary-darker);
        font-size: clamp(0.65rem, 3vw, var(--text-sm));
        font-weight: 800;
        letter-spacing: 0.05em;
        text-align: center;
        white-space: nowrap;
    }

    /* ==========================================================
       BẢN LỀ RESPONSIVE CHO PC (THIẾT KẾ MỚI THEO YÊU CẦU)
       Chỉ dùng sức mạnh của Flexbox, tuyệt đối không chạm vào HTML
    ========================================================== */
    @media (min-width: 1024px) {
        .site-footer {
            --banner-h: 60px; /* Tăng chiều cao banner trên PC */
            --checker-cols: 3; /* Tăng số cột Caro để tạo điểm nhấn */
            flex-direction: row; /* Bẻ giao diện từ Dọc sang Ngang */
            align-items: stretch; /* Ép 2 khối cao bằng nhau */
            padding-top: var(--spacing-2);
        }

        .footer-socials {
            flex: 0 0 45vw; /* Đẩy khối nền trắng chứa Icon chiếm 45% màn hình bên trái */
            padding: 0; /* Xóa padding để tự fit theo chiều cao flex cha */
            background-color: var(--bg-primary);
        }

        .footer-banner {
            flex: 1; /* Khối màu xanh chiếm toàn bộ phần bên phải còn lại */
        }

        /* YÊU CẦU CỦA CẬU: TẮT CARO BÊN PHẢI. Dùng CSS tắt cái rụp, không cần xóa DOM */
        .footer-banner::after {
            display: none;
        }

        /* ÉP COPYRIGHT SANG PHẢI VÀ TẠO KHOẢNG CÁCH */
        .footer-copyright {
            justify-content: center; /* Đẩy chữ về mép phải */
            padding-right: var(--spacing-10); /* Cách lề phải một đoạn chuẩn */
            font-size: var(
                --text-base
            ); /* Trả lại cỡ chữ bình thường trên PC */
        }
    }
</style>
