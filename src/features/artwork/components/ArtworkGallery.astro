---
import type { Page } from "astro";
import type { Artwork } from "../../../lib/hygraph";
import SectionHeader from "../../../components/SectionHeader.astro";
import FilterMenu from "../../../components/FilterMenu.astro";

interface Props {
  page: Page<Artwork>;
}

const { page } = Astro.props;
---

<div class="works-content">
  <artwork-gallery-manager>
    <section class="gallery-view" id="works-gallery">
      <SectionHeader title="ARTWORK" subtitle="作品" align="responsive" />

      <div class="wrapper artwork-wrapper">
        <div class="gallery-layout-split">
          <aside class="sidebar-desktop">
            <div class="sidebar-sticky-wrap">
              <div class="sidebar-group">
                <button class="s-btn grid-btn" data-cols="2" aria-label="2 Cột">
                  <svg viewBox="0 0 32 32"
                    ><rect x="4" y="11" width="10" height="10" rx="2"
                    ></rect><rect x="18" y="11" width="10" height="10" rx="2"
                    ></rect></svg
                  >
                </button>
                <button
                  class="s-btn grid-btn active"
                  data-cols="3"
                  aria-label="3 Cột"
                >
                  <svg viewBox="0 0 32 32"
                    ><rect x="1.5" y="7" width="8" height="8" rx="2"
                    ></rect><rect x="12" y="7" width="8" height="8" rx="2"
                    ></rect><rect x="22.5" y="7" width="8" height="8" rx="2"
                    ></rect><rect x="1.5" y="17.5" width="8" height="8" rx="2"
                    ></rect><rect x="12" y="17.5" width="8" height="8" rx="2"
                    ></rect><rect x="22.5" y="17.5" width="8" height="8" rx="2"
                    ></rect></svg
                  >
                </button>
                <button class="s-btn grid-btn" data-cols="4" aria-label="4 Cột">
                  <svg viewBox="0 0 42 42">
                    <rect x="2" y="12" width="8" height="8" rx="2"></rect>
                    <rect x="12" y="12" width="8" height="8" rx="2"></rect>
                    <rect x="22" y="12" width="8" height="8" rx="2"></rect>
                    <rect x="32" y="12" width="8" height="8" rx="2"></rect>
                    <rect x="2" y="22" width="8" height="8" rx="2"></rect>
                    <rect x="12" y="22" width="8" height="8" rx="2"></rect>
                    <rect x="22" y="22" width="8" height="8" rx="2"></rect>
                    <rect x="32" y="22" width="8" height="8" rx="2"></rect>
                  </svg>
                </button>
                <button class="s-btn grid-btn" data-cols="5" aria-label="5 Cột">
                  <svg viewBox="0 0 52 42">
                    <rect x="2" y="12" width="8" height="8" rx="2"></rect>
                    <rect x="12" y="12" width="8" height="8" rx="2"></rect>
                    <rect x="22" y="12" width="8" height="8" rx="2"></rect>
                    <rect x="32" y="12" width="8" height="8" rx="2"></rect>
                    <rect x="42" y="12" width="8" height="8" rx="2"></rect>
                    <rect x="2" y="22" width="8" height="8" rx="2"></rect>
                    <rect x="12" y="22" width="8" height="8" rx="2"></rect>
                    <rect x="22" y="22" width="8" height="8" rx="2"></rect>
                    <rect x="32" y="22" width="8" height="8" rx="2"></rect>
                    <rect x="42" y="22" width="8" height="8" rx="2"></rect>
                  </svg>
                </button>
              </div>

              <div class="sidebar-group filter-group">
                <button
                  class="s-btn filter-btn vertical-text active"
                  data-value="all">ALL</button
                >
                <button
                  class="s-btn filter-btn vertical-text"
                  data-value="featured">FEATURED</button
                >
              </div>
            </div>
          </aside>

          <div class="gallery-main">
            <FilterMenu
              groupName="artwork-filter"
              options={[
                { label: "ALL LABELS", value: "all" },
                { label: "ILLUSTRATION", value: "illustration" },
                { label: "GRAPHICS DESIGN", value: "graphics-design" },
              ]}
            />

            <div
              class="artwork-masonry"
              id="artwork-grid-container"
              data-grid-cols="default"
            >
              {
                page.data.map((art, index) => {
                  const catMatch = art.category?.slug || "all";
                  const visMatch = art.isFeatured ? "featured" : "all";

                  return (
                    <div
                      class="artwork-card"
                      role="button"
                      tabindex="0"
                      data-category={catMatch}
                      data-visibility={visMatch}
                      data-full-src={art.image.fullUrl || art.image.url}
                    >
                      <img
                        src={art.image.url}
                        loading={index < 3 ? "eager" : "lazy"}
                        fetchpriority={index < 3 ? "high" : "auto"}
                        decoding={index < 3 ? "sync" : "async"}
                        alt={art.title}
                      />
                    </div>
                  );
                })
              }
            </div>

            <hr class="artwork-loader-decor" />

            <!-- Client-side pagination container -->
            <nav id="artwork-pagination" aria-label="Artwork pagination"></nav>
          </div>
        </div>
      </div>

      <dialog class="lightbox-modal">
        <header class="lightbox-header">
          <div class="lightbox-title-group">
            <h2 class="lightbox-title">PREVIEW</h2>
          </div>
          <button class="lightbox-close" aria-label="Close preview">✕</button>
        </header>
        <div class="lightbox-body">
          <img src="" alt="" class="lightbox-img" decoding="async" />
        </div>
      </dialog>
    </section>
  </artwork-gallery-manager>
</div>

<script>
  const _preloadCache = new Set<HTMLImageElement>();

  class ArtworkGalleryManager
    extends HTMLElement
    implements EventListenerObject
  {
    private _dialog: HTMLDialogElement | null = null;
    private _closeBtn: HTMLButtonElement | null = null;
    private _galleryContainer: HTMLElement | null = null;

    private get _cards() {
      return this.querySelectorAll<HTMLElement>(".artwork-card");
    }

    private _currentCat = "all";
    private _currentVis = "all";
    private _currentPage = 1;
    private readonly _pageSize = 20;

    constructor() {
      super();
      this.handleCardClick = this.handleCardClick.bind(this);
      this.handleCardHover = this.handleCardHover.bind(this);
      this.closeDialog = this.closeDialog.bind(this);
      this.handleBackdropClick = this.handleBackdropClick.bind(this);
      this._handleKeydown = this._handleKeydown.bind(this);
    }

    private _resizeHandler = () => {
      requestAnimationFrame(() => {
        this.querySelectorAll(".sidebar-group").forEach((group) => {
          const activeBtn = group.querySelector(".s-btn.active") as HTMLElement;
          if (activeBtn) {
            if (activeBtn.offsetHeight === 0) {
              (group as HTMLElement).style.setProperty(
                "--tracker-opacity",
                "0",
              );
            } else {
              const offsetTop =
                activeBtn.offsetTop + activeBtn.offsetHeight / 2;
              (group as HTMLElement).style.setProperty(
                "--tracker-y",
                `${offsetTop}px`,
              );
              (group as HTMLElement).style.setProperty(
                "--tracker-opacity",
                "1",
              );
            }
          }
        });
      });
    };

    private performFLIP(updateDOMCallback: () => void) {
      if (this._cards.length === 0) return;

      const firstRects = new Map<HTMLElement, DOMRect>();
      this._cards.forEach((card) => {
        if (!card.hidden) firstRects.set(card, card.getBoundingClientRect());
      });

      updateDOMCallback();

      const lastRects = new Map<HTMLElement, DOMRect>();
      this._cards.forEach((card) => {
        if (!card.hidden) lastRects.set(card, card.getBoundingClientRect());
      });

      this._cards.forEach((card) => {
        if (card.hidden || !firstRects.has(card)) return;

        const first = firstRects.get(card)!;
        const last = lastRects.get(card)!;

        const dx = first.left - last.left;
        const dy = first.top - last.top;
        const dw = first.width / last.width;
        const dh = first.height / last.height;

        if (dx === 0 && dy === 0 && dw === 1 && dh === 1) return;

        card.style.transition = "none";
        card.style.transformOrigin = "top left";
        card.style.transform = `translate(${dx}px, ${dy}px) scale(${dw}, ${dh})`;
        card.style.zIndex = "10";

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            card.style.transition =
              "transform 0.5s cubic-bezier(0.22, 1, 0.36, 1)";
            card.style.transform = "";

            const cleanup = () => {
              card.style.transition = "";
              card.style.transformOrigin = "";
              card.style.zIndex = "";
              card.removeEventListener("transitionend", cleanup);
            };
            card.addEventListener("transitionend", cleanup);
          });
        });
      });
    }

    // =============================================
    //  CLIENT-SIDE PAGINATION ENGINE
    // =============================================

    private _getFilteredCards(): HTMLElement[] {
      return Array.from(this._cards).filter((card) => {
        const matchCat =
          this._currentCat === "all" ||
          card.dataset.category === this._currentCat;
        const matchVis =
          this._currentVis === "all" ||
          card.dataset.visibility === this._currentVis;
        return matchCat && matchVis;
      });
    }

    private _applyVisibility() {
      const allCards = Array.from(this._cards);
      const filtered = this._getFilteredCards();
      const totalPages = Math.max(
        1,
        Math.ceil(filtered.length / this._pageSize),
      );
      if (this._currentPage > totalPages) this._currentPage = totalPages;

      const start = (this._currentPage - 1) * this._pageSize;
      const pageSet = new Set(filtered.slice(start, start + this._pageSize));

      allCards.forEach((card) => {
        card.hidden = !pageSet.has(card);
      });

      this._renderPagination(totalPages);
    }

    private _renderPagination(totalPages: number) {
      const container = this.querySelector<HTMLElement>("#artwork-pagination");
      if (!container) return;

      const MAX_VISIBLE = 5;
      let ws = Math.max(1, this._currentPage - Math.floor(MAX_VISIBLE / 2));
      let we = ws + MAX_VISIBLE - 1;
      if (we > totalPages) {
        we = totalPages;
        ws = Math.max(1, we - MAX_VISIBLE + 1);
      }

      const prevPage =
        this._currentPage > 1 ? this._currentPage - 1 : totalPages;
      const nextPage =
        this._currentPage < totalPages ? this._currentPage + 1 : 1;

      let html = `<button class="page-nav-btn prev-btn" data-page="${prevPage}" aria-label="Previous page">PREVIOUS</button>`;
      html += `<ul class="page-numbers">`;
      for (let p = ws; p <= we; p++) {
        const active = p === this._currentPage;
        html += `<li><button class="page-link${active ? " is-active" : ""}" data-page="${p}" ${active ? 'aria-current="page"' : ""} aria-label="Page ${p}">${p}</button></li>`;
      }
      html += `</ul>`;
      html += `<button class="page-nav-btn next-btn" data-page="${nextPage}" aria-label="Next page">NEXT</button>`;

      container.innerHTML = html;
    }

    private _handlePaginationClick(btn: HTMLElement) {
      const page = parseInt(btn.dataset.page || "1", 10);
      if (page === this._currentPage || isNaN(page)) return;
      this._currentPage = page;

      const gallery = this.querySelector("#works-gallery");
      if (gallery)
        gallery.scrollIntoView({ behavior: "smooth", block: "start" });

      this.performFLIP(() => this._applyVisibility());
    }

    // =============================================
    //  LIFECYCLE
    // =============================================

    connectedCallback() {
      this._dialog = this.querySelector<HTMLDialogElement>(".lightbox-modal");
      this._closeBtn = this.querySelector<HTMLButtonElement>(".lightbox-close");
      this._galleryContainer = this.querySelector<HTMLElement>(
        "#artwork-grid-container",
      );

      if (this._galleryContainer !== null) {
        this._galleryContainer.addEventListener("click", this.handleCardClick);
        this._galleryContainer.addEventListener(
          "mouseover",
          this.handleCardHover,
        );
      }
      if (this._closeBtn !== null) {
        this._closeBtn.addEventListener("click", this.closeDialog);
      }
      if (this._dialog !== null) {
        this._dialog.addEventListener("click", this.handleBackdropClick);
        this._dialog.addEventListener("cancel", (e) => {
          e.preventDefault();
          this.closeDialog();
        });
      }

      const grid = this.querySelector<HTMLElement>("#artwork-grid-container");
      const sidebarBtns = this.querySelectorAll<HTMLButtonElement>(".s-btn");

      const savedCols = localStorage.getItem("kime-artwork-cols");
      if (savedCols && grid) {
        grid.dataset.gridCols = savedCols;
        sidebarBtns.forEach((b) => {
          if (b.classList.contains("grid-btn")) {
            if (b.dataset.cols === savedCols) b.classList.add("active");
            else b.classList.remove("active");
          }
        });
      }

      this._applyVisibility();

      window.addEventListener("resize", this._resizeHandler);
      this._resizeHandler();

      this.addEventListener("filter-changed", this);
      this.addEventListener("click", this);

      // Keyboard shortcuts: phím 2-5 chuyển cột grid tương ứng
      window.addEventListener("keydown", this._handleKeydown);

      const pendingSidebar = localStorage.getItem(
        "kime-sidebar-artwork-pending",
      );
      if (pendingSidebar) {
        localStorage.removeItem("kime-sidebar-artwork-pending");
        const targetBtn = this.querySelector<HTMLButtonElement>(
          `.sidebar-desktop .filter-btn[data-value="${CSS.escape(pendingSidebar)}"]`,
        );
        if (targetBtn) {
          this.querySelectorAll(".sidebar-desktop .filter-btn").forEach((b) =>
            b.classList.remove("active"),
          );
          targetBtn.classList.add("active");
          this._updateSidebarTracker(targetBtn);
        }
        requestAnimationFrame(() => {
          this.dispatchEvent(
            new CustomEvent("filter-changed", {
              detail: {
                group: "sidebar",
                value: pendingSidebar,
                isRestore: true,
              },
              bubbles: true,
            }),
          );
        });
      }
    }

    disconnectedCallback() {
      window.removeEventListener("resize", this._resizeHandler);
      window.removeEventListener("keydown", this._handleKeydown);
      this.removeEventListener("filter-changed", this);
      this.removeEventListener("click", this);

      if (this._galleryContainer !== null) {
        this._galleryContainer.removeEventListener(
          "click",
          this.handleCardClick,
        );
        this._galleryContainer.removeEventListener(
          "mouseover",
          this.handleCardHover,
        );
      }
      if (this._closeBtn !== null) {
        this._closeBtn.removeEventListener("click", this.closeDialog);
      }
      if (this._dialog !== null) {
        this._dialog.removeEventListener("click", this.handleBackdropClick);
      }
    }

    handleEvent(e: Event) {
      if (e.type === "filter-changed") {
        this._handleFilterChange(e as CustomEvent);
      } else if (e.type === "click") {
        const target = e.target as HTMLElement;
        const sidebarBtn = target.closest<HTMLButtonElement>(".s-btn");
        if (sidebarBtn) {
          this._handleSidebarClick(sidebarBtn);
          return;
        }
        const pageBtn = target.closest<HTMLElement>("[data-page]");
        if (pageBtn) this._handlePaginationClick(pageBtn);
      }
    }

    // Keyboard shortcut handler: phím 2/3/4/5 -> chuyển cột grid
    private _handleKeydown(e: KeyboardEvent) {
      // Bỏ qua nếu user đang gõ text hoặc popup đang mở
      if (this._dialog?.open) return;
      const active = document.activeElement;
      if (active && (active.tagName === "INPUT" || active.tagName === "TEXTAREA" || (active as HTMLElement).isContentEditable)) return;

      const colMap: Record<string, string> = { "2": "2", "3": "3", "4": "4", "5": "5" };
      const cols = colMap[e.key];
      if (!cols) return;

      const targetBtn = this.querySelector<HTMLButtonElement>(`.grid-btn[data-cols="${cols}"]`);
      if (targetBtn && !targetBtn.classList.contains("active")) {
        this._handleSidebarClick(targetBtn);
      }
    }

    private _updateSidebarTracker(btn: HTMLElement) {
      const group = btn.closest(".sidebar-group") as HTMLElement;
      if (group) {
        if (btn.offsetHeight === 0) {
          group.style.setProperty("--tracker-opacity", "0");
        } else {
          const offsetTop = btn.offsetTop + btn.offsetHeight / 2;
          group.style.setProperty("--tracker-y", `${offsetTop}px`);
          group.style.setProperty("--tracker-opacity", "1");
        }
      }
    }

    private _handleSidebarClick(btn: HTMLButtonElement) {
      this._updateSidebarTracker(btn);
      const grid = this.querySelector<HTMLElement>("#artwork-grid-container");

      if (btn.classList.contains("grid-btn")) {
        this.querySelectorAll(".grid-btn").forEach((b) =>
          b.classList.remove("active"),
        );
        btn.classList.add("active");

        if (
          grid &&
          btn.dataset.cols &&
          grid.dataset.gridCols !== btn.dataset.cols
        ) {
          this.performFLIP(() => {
            grid.dataset.gridCols = btn.dataset.cols!;
            localStorage.setItem("kime-artwork-cols", btn.dataset.cols!);
          });
        }
      }

      if (btn.classList.contains("filter-btn")) {
        this.querySelectorAll(
          ".filter-btn:not(filter-menu-ctrl .filter-btn)",
        ).forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        const filterValue = btn.dataset.value;
        if (filterValue) {
          this.dispatchEvent(
            new CustomEvent("filter-changed", {
              detail: { group: "sidebar", value: filterValue },
              bubbles: true,
            }),
          );
        }
      }
    }

    private _handleFilterChange(e: CustomEvent) {
      if (this._cards.length === 0) return;
      const filterGroup = e.detail.group;
      const filterValue = e.detail.value.toLowerCase();
      if (filterGroup === "sidebar") {
        this._currentVis = filterValue;
      } else {
        this._currentCat = filterValue;
      }
      this._currentPage = 1;
      this.performFLIP(() => this._applyVisibility());
    }

    // =============================================
    //  LIGHTBOX
    // =============================================

    private closeDialog() {
      if (this._dialog !== null) {
        this._dialog.classList.add("is-closing");
        this._dialog.addEventListener(
          "animationend",
          () => {
            this._dialog?.classList.remove("is-closing");
            this._dialog?.close();
          },
          { once: true }
        );
      }
    }

    private handleBackdropClick(e: MouseEvent) {
      if (e.target === this._dialog && this._dialog !== null) {
        this.closeDialog();
      }
    }

    private handleCardHover(e: MouseEvent) {
      const target = e.target as HTMLElement;
      const card = target.closest<HTMLElement>(".artwork-card");
      if (card === null) return;
      const fullSrc = card.dataset.fullSrc;
      if (fullSrc !== undefined && card.dataset.preloaded !== "true") {
        card.dataset.preloaded = "true";
        const preloadImg = new Image();
        _preloadCache.add(preloadImg);
        preloadImg.onload = preloadImg.onerror = () =>
          _preloadCache.delete(preloadImg);
        preloadImg.src = fullSrc;
      }
    }

    private handleCardClick(e: MouseEvent) {
      const target = e.target as HTMLElement;
      const card = target.closest<HTMLElement>(".artwork-card");
      if (card === null || this._dialog === null) return;
      const fullSrc = card.dataset.fullSrc;
      const img = card.querySelector("img");
      if (fullSrc === undefined || img === null) return;
      const dialogImg =
        this._dialog.querySelector<HTMLImageElement>(".lightbox-img");
      if (dialogImg !== null) {
        const padding = 32; // Padding of body
        const headerOffset = 60; // Header height
        const maxW = window.innerWidth * 0.95 - padding;
        const maxH = window.innerHeight * 0.95 - headerOffset - padding;
        
        // Use the original size of the thumbnail to get the ratio
        const natW = img.naturalWidth || 800;
        const natH = img.naturalHeight || 800;
        const scale = Math.min(maxW / natW, maxH / natH);
        
        // Gán cứng kích thước đích trước khi show popup
        dialogImg.style.width = `${Math.floor(natW * scale)}px`;
        dialogImg.style.height = `${Math.floor(natH * scale)}px`;

        dialogImg.src = img.src;
        dialogImg.alt = img.alt || "Expanded artwork preview";
        this._dialog.showModal();
        if (fullSrc !== img.src) {
          const highResLoader = new Image();
          highResLoader.onload = () => {
            if (dialogImg.src === img.src) dialogImg.src = fullSrc;
          };
          highResLoader.src = fullSrc;
        }
      }
    }
  }

  if (customElements.get("artwork-gallery-manager") === undefined) {
    customElements.define("artwork-gallery-manager", ArtworkGalleryManager);
  }
</script>

<style>
  /* Base styles */
  .works-content {
    padding-top: var(--spacing-8);
  }
  artwork-gallery-manager {
    display: block;
    width: 100%;
    min-height: 50vh;
  }
  :global(.artwork-card[hidden]) {
    display: none;
  }

  /* Layout Split */
  .gallery-layout-split {
    display: flex;
    flex-direction: column;
    margin-top: var(--spacing-8);
  }
  .sidebar-desktop {
    display: none;
  }

  @media (min-width: 1024px) {
    .gallery-layout-split {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: clamp(16px, 4vw, 80px);
    }
    .gallery-main {
      flex: 1;
      width: 100%;
      min-width: 0;
    }

    .sidebar-desktop {
      display: block;
      margin-top: calc(48px + var(--spacing-8));
      position: sticky;
      top: calc(var(--header-height-pc) + var(--spacing-8));
      width: clamp(48px, 4vw, 72px);
      flex-shrink: 0;
    }
    .sidebar-sticky-wrap {
      display: flex;
      flex-direction: column;
      gap: clamp(40px, 4vw, 72px);
      align-items: center;
    }
    .sidebar-group {
      display: flex;
      flex-direction: column;
      gap: clamp(24px, 2vw, 32px);
      align-items: center;
      position: relative;
    }
    .s-btn {
      position: relative;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      padding: 0;
      transition: opacity 0.2s ease;
    }
    .s-btn:active {
      opacity: 0.6;
    }

    .sidebar-group::after {
      content: "";
      position: absolute;
      right: clamp(-24px, -2vw, -32px);
      top: 0;
      transform: translateY(calc(var(--tracker-y, 16px) - 50%));
      width: 0;
      height: 0;
      border-top: 8px solid transparent;
      border-bottom: 8px solid transparent;
      border-right: clamp(10px, 1vw, 14px) solid var(--color-primary);
      will-change: transform;
      transition:
        transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
        opacity 0.2s ease;
      opacity: var(--tracker-opacity, 1);
    }

    .grid-btn svg {
      width: clamp(32px, 3vw, 44px);
      height: clamp(32px, 3vw, 44px);
      fill: rgba(250, 114, 157, 0.3);
      transition: fill 0.2s ease;
    }
    .grid-btn:hover svg {
      fill: rgba(250, 114, 157, 0.7);
    }
    .grid-btn.active svg {
      fill: var(--color-primary);
    }

    .vertical-text {
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      font-size: clamp(16px, 1.5vw, 22px);
      font-weight: 899;
      letter-spacing: 3px;
      color: #b0b0b0;
      text-transform: uppercase;
    }
    .vertical-text:hover {
      color: var(--color-primary-light);
    }
    .vertical-text.active {
      color: var(--base-black-800);
    }
  }

  /* Masonry Base */
  .artwork-masonry {
    column-count: 1;
    column-gap: var(--spacing-4);
    padding-top: var(--spacing-4);

    padding-bottom: clamp(var(--spacing-8), 8vw, var(--spacing-16));
  }

  @media (max-width: 639.98px) {
    .artwork-masonry,
    .artwork-masonry[data-grid-cols] {
      column-count: 1 !important;
    }
  }

